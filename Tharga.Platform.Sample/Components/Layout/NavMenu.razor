@using Microsoft.AspNetCore.Authorization

<RadzenStack Orientation="Orientation.Vertical" Gap="0" class="rz-h-100">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" class="rz-p-3">
        <RadzenIcon Icon="hub" />
        <RadzenText TextStyle="TextStyle.H6" class="rz-m-0">Platform Sample</RadzenText>
    </RadzenStack>

    <RadzenPanelMenu>
        <RadzenPanelMenuItem Text="Home" Path="" Icon="home" />
        <RadzenPanelMenuItem Text="Team" Path="team" Icon="groups" />
        <RadzenPanelMenuItem Text="API Keys" Path="api-keys" Icon="key" />
        <RadzenPanelMenuItem Text="Scopes" Path="scopes" Icon="shield" />
        <RadzenPanelMenuItem Text="Custom roles" Path="roles" Icon="admin_panel_settings" />
        <AuthorizeView Roles="@Tharga.Team.Blazor.Framework.Roles.Developer">
            <Authorized>
                <RadzenPanelMenuItem Text="System API Keys" Path="system-api-keys" Icon="vpn_key" />
            </Authorized>
        </AuthorizeView>
        <RadzenPanelMenuItem Text="Audit" Path="audit" Icon="receipt_long" />
        <RadzenPanelMenuItem Text="Profile" Path="profile" Icon="person" />
        <RadzenPanelMenuItem Text="Users" Path="users" Icon="people" />
        <RadzenPanelMenuItem Text="Invites" Path="invites" Icon="mail" />
    </RadzenPanelMenu>
</RadzenStack>
