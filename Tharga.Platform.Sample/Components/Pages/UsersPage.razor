@page "/users"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Developer")]
@using Microsoft.AspNetCore.Authorization
@using Tharga.Platform.Sample.Framework.Team
@using Tharga.Team.Blazor.Features.User
@inject AppUserAdminService UserAdmin
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject NavigationManager Navigation

<PageTitle>Users</PageTitle>

@*
    The packaged tabbed admin view: Users (with last seen, verify + delete when the caller holds
    users:manage), Teams, and — when a directory service is registered — the "Users in directory only" tab.
    The sample's own Edit action rides in each row's split-button dropdown via ActionItems/ActionInvoked;
    View, Verify and Delete are built in.
*@
<UsersView TMember="TeamMember" ActionInvoked="OnUserActionAsync">
    <ActionItems>
        <RadzenSplitButtonItem Text="Edit" Value="@EditAction" Icon="edit" />
    </ActionItems>
</UsersView>

@code {
    private const string EditAction = "edit";

    private async Task OnUserActionAsync(UserRowAction action)
    {
        if (action.Action == EditAction) await EditUser(action.User);
    }

    private async Task EditUser(UserViewModel u)
    {
        var name = u.Name ?? "";
        var email = u.EMail ?? "";

        var result = await DialogService.OpenAsync("Edit user", ds =>
            @<RadzenStack Gap="0.75rem">
                <RadzenStack Gap="0.25rem">
                    <RadzenLabel Text="Name" />
                    <RadzenTextBox Value="@name" ValueChanged="@(v => name = v)" Style="width: 100%;" />
                </RadzenStack>
                <RadzenStack Gap="0.25rem">
                    <RadzenLabel Text="Email" />
                    <RadzenTextBox Value="@email" ValueChanged="@(v => email = v)" Style="width: 100%;" />
                </RadzenStack>
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
                    <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="@(_ => ds.Close(false))" />
                    <RadzenButton Text="Save" ButtonStyle="ButtonStyle.Primary" Click="@(_ => ds.Close(true))" />
                </RadzenStack>
            </RadzenStack>,
            new DialogOptions { Width = "420px" });

        if (result is not true) return;

        await UserAdmin.UpdateAsync(u.Key, name, email);
        NotificationService.Notify(NotificationSeverity.Success, "User updated");
        Navigation.Refresh();
    }
}
