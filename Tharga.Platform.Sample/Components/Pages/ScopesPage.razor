@page "/scopes"
@rendermode InteractiveServer
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Tharga.Team.Blazor.Features.Scopes

<PageTitle>Scopes</PageTitle>

<RadzenText TextStyle="TextStyle.Body2" class="rz-mb-3">
    Reference of the scopes configured for this application — which access levels and roles grant each scope,
    and what each scope is for. Rebuilt dynamically from the configured registries.
</RadzenText>

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1.5rem" class="rz-mb-3">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
        <RadzenSwitch @bind-Value="_showDescription" /> <RadzenLabel Text="Show description" />
    </RadzenStack>
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
        <RadzenSwitch @bind-Value="_showRoles" /> <RadzenLabel Text="Show roles" />
    </RadzenStack>
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
        <RadzenSwitch @bind-Value="_allowFiltering" /> <RadzenLabel Text="Allow filtering" />
    </RadzenStack>
</RadzenStack>

<ScopeView ShowDescription="_showDescription" ShowRoles="_showRoles" AllowGridFiltering="_allowFiltering" />

@code {
    private bool _showDescription = true;
    private bool _showRoles = true;
    private bool _allowFiltering;
}
