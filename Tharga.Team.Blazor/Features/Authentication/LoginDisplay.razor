@using Microsoft.Extensions.Options
@using Tharga.Toolkit
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IOptions<ThargaBlazorOptions> ThargaBlazorOptions;
@inject IThargaTextProvider TextProvider

<CascadingAuthenticationState>
    <AuthorizeView>
        <Authorized>
            <RadzenProfileMenu Click="@(ClickAction)" title="@_email">
                <Template>
                    <RadzenGravatar Email="@_email" AlternateText="@_email" />
                </Template>
                <ChildContent>
                    <RadzenProfileMenuItem Text="@_userText" Icon="account_circle" />
                    <RadzenProfileMenuItem Text="@_teamText" Icon="group" Visible="@GetShowTeam()" />
                    <hr style="margin: 0;" />
                    <RadzenProfileMenuItem Text="@_logoutText" Icon="logout" />
                </ChildContent>
            </RadzenProfileMenu>
        </Authorized>
        <NotAuthorized>
            <RadzenButton Text="@_loginText" Icon="login" Click="Login" />
        </NotAuthorized>
    </AuthorizeView>
</CascadingAuthenticationState>
<div>&nbsp;</div>

@code {
    private string _email;
    private bool _showTeamDefault;
    private bool _hasTeamMenuRoleRestriction;
    private bool _userInTeamMenuRole;
    private string _userText = TeamMenuText.User.Default;
    private string _teamText = TeamMenuText.Team.Default;
    private string _logoutText = TeamMenuText.Logout.Default;
    private string _loginText = TeamMenuText.Login.Default;

    [Parameter]
    public bool? ShowTeam { get; set; }

    /// <summary>
    /// Restricts the Team profile-menu item to users in at least one of the given roles. When null or
    /// empty (the default) the item is shown to every authenticated user, exactly as before.
    /// </summary>
    [Parameter]
    public string[] TeamMenuRoles { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _showTeamDefault = ThargaBlazorOptions.Value._teamService != null;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated ?? false)
        {
            _email = authState.User.GetEmail();
        }

        var teamMenuRoles = TeamMenuRoles?.Where(x => !string.IsNullOrWhiteSpace(x)).ToArray() ?? [];
        _hasTeamMenuRoleRestriction = teamMenuRoles.Length > 0;
        _userInTeamMenuRole = teamMenuRoles.Any(authState.User.IsInRole);

        _userText = await TextProvider.GetAsync(TeamMenuText.User);
        _teamText = await TextProvider.GetAsync(TeamMenuText.Team);
        _logoutText = await TextProvider.GetAsync(TeamMenuText.Logout);
        _loginText = await TextProvider.GetAsync(TeamMenuText.Login);

        await base.OnInitializedAsync();
    }

    private async Task ClickAction(RadzenProfileMenuItem args)
    {
        switch (args.Icon)
        {
            case "account_circle":
                NavigationManager.NavigateTo("profile");
                break;
            case "group":
                NavigationManager.NavigateTo("team");
                break;
            case "logout":
                await Logout();
                break;
            default:
                throw new ArgumentOutOfRangeException($"Unknown action '{args.Icon}'.");
        }
    }

    private Task Login()
    {
        NavigationManager.NavigateTo("/login", forceLoad: true);
        return Task.CompletedTask;
    }

    private Task Logout()
    {
        NavigationManager.NavigateTo("/logout", forceLoad: true);
        return Task.CompletedTask;
    }

    private bool GetShowTeam() => ShouldShowTeamMenuItem(ShowTeam, _showTeamDefault, _hasTeamMenuRoleRestriction, _userInTeamMenuRole);

    internal static bool ShouldShowTeamMenuItem(bool? showTeam, bool showTeamDefault, bool hasRoleRestriction, bool userInAnyRole)
    {
        var visible = showTeam ?? showTeamDefault;
        if (!visible) return false;
        if (!hasRoleRestriction) return true;
        return userInAnyRole;
    }
}
