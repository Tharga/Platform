@using Microsoft.Extensions.DependencyInjection
@using Microsoft.JSInterop
@using Tharga.Team
@using Tharga.Team.Blazor.Framework
@inject IServiceProvider ServiceProvider
@inject IJSRuntime Js
@inject DialogService DialogService
@inject NotificationService NotificationService

<AuthorizeView Roles="@Roles.Developer" Context="authState">
    <Authorized>
        @if (_apiKeyServiceMissing)
        {
            <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" Variant="Variant.Flat">
                API key management is not configured. Register <code>IApiKeyManagementService</code> in Program.cs to enable this view.
            </RadzenAlert>
        }
        else if (_keys == null)
        {
            <Loading />
        }
        else
        {
            <RadzenDataGrid Data="@_keys" TItem="SystemApiKeyModel">
                <Columns>
                    <RadzenDataGridColumn Title="Name" Property="@nameof(SystemApiKeyModel.Name)" Width="180px" />
                    <RadzenDataGridColumn Title="Key" Property="@nameof(SystemApiKeyModel.VisibleKey)" />
                    <RadzenDataGridColumn Title="Scopes" Width="80px" Visible="@ShowScopeTooltip">
                        <Template>
                            <span title="@GetKeyScopesText(context)">
                                <RadzenIcon Icon="info" Style="cursor: help;" />
                            </span>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Title="Last used" Width="150px" Visible="@ShowLastUsed">
                        <Template>
                            <span title="@GetKeyDatesText(context)">
                                @if (context.LastUsedAt.HasValue)
                                {
                                    <DateTimeView Date="@context.LastUsedAt" />
                                }
                                else
                                {
                                    <RadzenText>Never</RadzenText>
                                }
                            </span>
                            @if (IsExpiringSoon(context))
                            {
                                <RadzenIcon Icon="warning" Style="color: var(--rz-warning); margin-left: .25rem; cursor: help;"
                                            title="@($"Expires {context.ExpiryDate:yyyy-MM-dd} — within 60 days")" />
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Width="@(ShowAuditLogButton ? "260px" : "220px")">
                        <Template>
                            <RadzenButton Icon="visibility" Click="@(_ => context.VisibleKey = context.ApiKey)" Visible="@(!string.IsNullOrEmpty(context.ApiKey) && context.VisibleKey == _apiKeyMask)" />
                            <RadzenButton Icon="visibility_off" Click="@(_ => context.VisibleKey = _apiKeyMask)" Visible="@(!string.IsNullOrEmpty(context.ApiKey) && context.VisibleKey != _apiKeyMask)" />
                            <RadzenButton Icon="content_copy" Click="@(_ => CopyToClipboard(context))" Visible="@(!string.IsNullOrEmpty(context.ApiKey))" />
                            <RadzenButton Icon="manage_search" Click="@(_ => OpenAuditLogAsync(context))" Visible="@ShowAuditLogButton" title="View audit log for this key" />
                            <RadzenButton Icon="lock" Click="@(_ => LockKeyAsync(context))" Visible="@(!string.IsNullOrEmpty(context.ApiKey))" />
                            <RadzenButton Icon="refresh" Click="@(_ => RefreshAsync(context))" />
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat" Click="@(_ => DeleteAsync(context))" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>

            <RadzenCard class="rz-mt-4">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" Gap="1rem" Wrap="FlexWrap.Wrap">
                    <RadzenStack Gap="0.25rem">
                        <RadzenLabel Text="Name" />
                        <RadzenTextBox Value="@_newName" @oninput="@(e => _newName = e.Value?.ToString() ?? "")" Placeholder="Key name" />
                    </RadzenStack>
                    @if (ShowScopeOverrides)
                    {
                        <RadzenStack Gap="0.25rem" Style="min-width: 260px">
                            <RadzenLabel Text="Scopes" />
                            <RadzenDropDown TValue="IEnumerable<string>"
                                            @bind-Value="_newScopes"
                                            Data="@_allScopes"
                                            Multiple="true"
                                            AllowClear="true"
                                            Placeholder="Select scopes...">
                                <Template>
                                    <span title="@(_scopeDescriptions.TryGetValue((string)context, out var d) ? d : null)">@context</span>
                                </Template>
                            </RadzenDropDown>
                        </RadzenStack>
                    }
                    @if (ShowExpiryDatePicker)
                    {
                        <RadzenStack Gap="0.25rem">
                            <RadzenLabel Text="Expiry Date" />
                            <RadzenDatePicker @bind-Value="_newExpiryDate" DateFormat="yyyy-MM-dd"
                                              AllowClear="true"
                                              Min="@DateTime.UtcNow.Date" />
                        </RadzenStack>
                    }
                    <RadzenButton Text="Create" Icon="add" Click="@CreateAsync"
                                  Disabled="@string.IsNullOrWhiteSpace(_newName)" />
                </RadzenStack>
            </RadzenCard>
        }
    </Authorized>
    <NotAuthorized>
        <RadzenText>Access denied. The Developer role is required to manage system API keys.</RadzenText>
    </NotAuthorized>
</AuthorizeView>

@code {
    /// <summary>
    /// When true, each row gets a "View audit log" button that opens a dialog scoped to that key
    /// (CallerKeyId pinned). Default false — opt in on Developer pages where the audit log is configured.
    /// </summary>
    [Parameter] public bool ShowAuditLogButton { get; set; }

    /// <summary>When true, shows the per-key scope (i) tooltip (lists the key's <c>SystemScopes</c>). Default true.</summary>
    [Parameter] public bool ShowScopeTooltip { get; set; } = true;

    /// <summary>When true, the create card offers a scope picker. Set false to create scopeless system keys. Default true.</summary>
    [Parameter] public bool ShowScopeOverrides { get; set; } = true;

    /// <summary>Shows the "Last used" column (tooltip lists Created + Expiry + Created By; a warning icon appears within 60 days of expiry). Default true.</summary>
    [Parameter] public bool ShowLastUsed { get; set; } = true;

    /// <summary>Shows the expiry-date picker on the create card. When hidden, new keys use the default expiry (capped by <c>ApiKeyOptions.MaxExpiryDays</c>). Default false.</summary>
    [Parameter] public bool ShowExpiryDatePicker { get; set; }

    private static string GetKeyScopesText(SystemApiKeyModel context)
        => string.Join("\n", (context.SystemScopes ?? Array.Empty<string>()).OrderBy(s => s, StringComparer.Ordinal));

    private static string GetKeyDatesText(SystemApiKeyModel context)
    {
        var created = context.CreatedAt.HasValue ? context.CreatedAt.Value.ToString("yyyy-MM-dd") : "—";
        var expires = context.ExpiryDate.HasValue ? context.ExpiryDate.Value.ToString("yyyy-MM-dd") : "No expiry";
        var by = string.IsNullOrWhiteSpace(context.CreatedBy) ? "—" : context.CreatedBy;
        return $"Created: {created}\nExpires: {expires}\nCreated by: {by}";
    }

    private static bool IsExpiringSoon(SystemApiKeyModel context)
        => context.ExpiryDate.HasValue && context.ExpiryDate.Value <= DateTime.UtcNow.AddDays(60);

    private bool _apiKeyServiceMissing;
    private IApiKeyManagementService _apiKeyManagementService;
    private ISystemScopeRegistry _systemScopeRegistry;
    private SystemApiKeyModel[] _keys;
    private string[] _allScopes = [];
    private IReadOnlyDictionary<string, string> _scopeDescriptions = new Dictionary<string, string>();
    private readonly string _apiKeyMask = "**********";

    private string _newName = "";
    private IEnumerable<string> _newScopes = Array.Empty<string>();
    private DateTime? _newExpiryDate;

    protected override async Task OnInitializedAsync()
    {
        _apiKeyManagementService = ServiceProvider.GetService<IApiKeyManagementService>();
        _apiKeyServiceMissing = _apiKeyManagementService == null;
        if (_apiKeyServiceMissing) { await base.OnInitializedAsync(); return; }

        _systemScopeRegistry = ServiceProvider.GetService<ISystemScopeRegistry>();
        _allScopes = _systemScopeRegistry?.All.Select(s => s.Name).ToArray() ?? [];
        _scopeDescriptions = _systemScopeRegistry?.All.ToDictionary(s => s.Name, s => s.Description) ?? new Dictionary<string, string>();

        await ReloadData();
        await base.OnInitializedAsync();
    }

    private async Task ReloadData()
    {
        var keys = await _apiKeyManagementService.GetSystemKeysAsync().ToArrayAsync();
        _keys = keys
            .Select(x => new SystemApiKeyModel
            {
                Key = x.Key,
                Name = x.Name,
                ApiKey = x.ApiKey,
                VisibleKey = _apiKeyMask,
                SystemScopes = x.SystemScopes ?? [],
                ExpiryDate = x.ExpiryDate,
                CreatedAt = x.CreatedAt,
                LastUsedAt = x.LastUsedAt,
                CreatedBy = x.CreatedBy,
            }).ToArray();

        StateHasChanged();
    }

    private async Task CreateAsync()
    {
        try
        {
            var created = await _apiKeyManagementService.CreateSystemKeyAsync(_newName, _newScopes?.ToArray() ?? [], _newExpiryDate);
            _newName = "";
            _newScopes = Array.Empty<string>();
            _newExpiryDate = null;
            await ReloadData();
            ShowKeyOnce(created);
            NotificationService.Notify(NotificationSeverity.Success, "System API key created");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Failed to create key", ex.Message);
        }
    }

    private async Task RefreshAsync(SystemApiKeyModel context)
    {
        var result = await DialogService.Confirm($"The {context.Name} key will be regenerated.", "Confirm regenerate API key");
        if (result != true) return;

        var refreshed = await _apiKeyManagementService.RefreshSystemKeyAsync(context.Key);
        await ReloadData();
        ShowKeyOnce(refreshed);
    }

    private void ShowKeyOnce(IApiKey key)
    {
        if (key == null || string.IsNullOrEmpty(key.ApiKey)) return;
        var model = _keys?.FirstOrDefault(k => k.Key == key.Key);
        if (model != null) model.VisibleKey = key.ApiKey;
        StateHasChanged();
    }

    private async Task CopyToClipboard(SystemApiKeyModel context)
    {
        var keyToCopy = context.VisibleKey != _apiKeyMask ? context.VisibleKey : context.ApiKey;
        await Js.InvokeVoidAsync("clipboard.copyText", keyToCopy);
        NotificationService.Notify(new NotificationMessage
        {
            Summary = $"The {context.Name} key has been copied to the clipboard."
        });
    }

    private async Task LockKeyAsync(SystemApiKeyModel context)
    {
        var result = await DialogService.Confirm($"The {context.Name} key will be locked. After that, it cannot be retrieved.", "Confirm lock API key");
        if (result != true) return;

        await _apiKeyManagementService.LockSystemKeyAsync(context.Key);
        await ReloadData();
    }

    private async Task DeleteAsync(SystemApiKeyModel context)
    {
        var result = await DialogService.Confirm($"Delete system API key '{context.Name}'? This cannot be undone.", "Confirm delete");
        if (result != true) return;

        try
        {
            await _apiKeyManagementService.DeleteSystemKeyAsync(context.Key);
            await ReloadData();
            NotificationService.Notify(NotificationSeverity.Success, "System API key deleted");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Failed to delete key", ex.Message);
        }
    }

    private async Task OpenAuditLogAsync(SystemApiKeyModel context)
    {
        var pinned = new Tharga.Team.Blazor.Features.Audit.AuditPinnedFilter
        {
            CallerKeyId = context.Key,
            CallerType = Tharga.Team.Service.Audit.AuditCallerType.ApiKey,
        };

        await DialogService.OpenAsync($"Audit log — {context.Name}", _ =>
            @<Tharga.Team.Blazor.Features.Audit.AuditLogView PinnedFilter="@pinned" />,
            new DialogOptions { Width = "90vw", Height = "85vh", Resizable = true, Draggable = true });
    }
}
