@using Microsoft.Extensions.DependencyInjection
@using Microsoft.Extensions.Options
@using Microsoft.JSInterop
@using Tharga.Team.Blazor.Features.Team
@inject ITeamStateService TeamStateService
@inject AuthenticationStateProvider AuthStateProvider
@inject IOptions<ApiKeyOptions> ApiKeyOptionsAccessor
@inject IServiceProvider ServiceProvider
@inject IJSRuntime Js
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject ContextMenuService ContextMenuService

@if (_apiKeyServiceMissing)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" Variant="Variant.Flat">
        API key management is not configured. Register <code>IApiKeyManagementService</code> in Program.cs to enable this view.
    </RadzenAlert>
}
else if (!_hasAccess)
{
    <RadzenText>Access denied. You need the API key management permission to view this page.</RadzenText>
}
else if (!_teamLoaded)
{
    <Loading />
}
else if (_selectedTeam == null)
{
    <RadzenText>No team selected.</RadzenText>
}
else if (_keys == null)
{
    <Loading />
}
else
{
    <RadzenDataGrid Data="@_keys" TItem="ApiKeyModel">
        <Columns>
            <RadzenDataGridColumn Title="Name" Property="@nameof(ApiKeyModel.Name)" Width="180px" />
            <RadzenDataGridColumn Title="Key" Property="@nameof(ApiKeyModel.VisibleKey)" />
            @if (_options.AdvancedMode)
            {
                <RadzenDataGridColumn Title="Access Level" Width="130px">
                    <Template>
                        @context.AccessLevel
                    </Template>
                </RadzenDataGridColumn>
                @* #76: Roles column hidden for the basic baseline — will become a Show* parameter later.
                <RadzenDataGridColumn Title="Roles" Width="150px">
                    <Template>
                        @string.Join(", ", context?.Roles ?? Array.Empty<string>())
                    </Template>
                </RadzenDataGridColumn>
                *@
            }
            @* #76: Expiry column hidden for the basic baseline — will become a Show* parameter later.
            @if (_options.AdvancedMode)
            {
                <RadzenDataGridColumn Title="Expiry" Width="130px">
                    <Template>
                        @if (context.ExpiryDate.HasValue)
                        {
                            <span style="@(context.IsExpired ? "color: red" : "")">
                                <DateTimeView Date="@context.ExpiryDate" />
                            </span>
                        }
                        else
                        {
                            <RadzenText>No expiry</RadzenText>
                        }
                    </Template>
                </RadzenDataGridColumn>
            }
            *@
            @* #76: the scope-override *display* column was redundant — overrides already show in the scope (i)
               tooltip (marked "(override)"). Editing is via the Edit-Scopes dialog (tune button) + create card. *@
            <RadzenDataGridColumn Title="Scopes" Width="80px" Visible="@(_scopeRegistry != null && ShowScopeTooltip)">
                <Template>
                    <span title="@GetKeyScopesText(context)">
                        <RadzenIcon Icon="info" Style="cursor: help;" />
                    </span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Title="Last used" Width="150px" Visible="@ShowLastUsed">
                <Template>
                    <span title="@GetKeyDatesText(context)">
                        @if (context.LastUsedAt.HasValue)
                        {
                            <DateTimeView Date="@context.LastUsedAt" />
                        }
                        else
                        {
                            <RadzenText>Never</RadzenText>
                        }
                    </span>
                    @if (IsExpiringSoon(context))
                    {
                        <RadzenIcon Icon="warning" Style="color: var(--rz-warning); margin-left: .25rem; cursor: help;"
                                    title="@($"Expires {context.ExpiryDate:yyyy-MM-dd} — within 60 days")" />
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Title="Tags" Width="180px" Visible="@(ShowTags ?? AnyKeyHasTags())">
                <Template>
                    @foreach (var tag in context.Tags.Where(t => ChipTagKeys.Contains(t.Key)))
                    {
                        <RadzenBadge Text="@tag.Value" class="rz-mr-1 rz-mb-1" />
                    }
                    @if (context.Tags.Count > 0)
                    {
                        <span title="@GetKeyTagsText(context)">
                            <RadzenIcon Icon="info" Style="cursor: help;" />
                        </span>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Width="56px" TextAlign="TextAlign.Right">
                <Template>
                    <RadzenButton Icon="more_vert" Variant="Variant.Flat" ButtonStyle="ButtonStyle.Base"
                                  Click="@(args => OpenRowMenu(args, context))" title="Actions" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>

    @if (_options.AdvancedMode)
    {
        <RadzenCard class="rz-mt-4">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" Gap="1rem">
                <RadzenStack Gap="0.25rem">
                    <RadzenLabel Text="Name" />
                    <RadzenTextBox Value="@_newName" @oninput="@(e => _newName = e.Value?.ToString() ?? "")" Placeholder="Key name" />
                </RadzenStack>
                <RadzenStack Gap="0.25rem">
                    <RadzenLabel Text="Access Level" />
                    <RadzenDropDown TValue="AccessLevel" @bind-Value="_newAccessLevel" Data="@_accessLevels" />
                </RadzenStack>
                @if (ShowRoles && _tenantRoleRegistry != null)
                {
                    <RadzenStack Gap="0.25rem">
                        <RadzenLabel Text="Roles" />
                        <RoleEditor Roles="_roleDefinitions"
                                    Selected="_newRoles"
                                    SelectedChanged="@(r => _newRoles = r.ToList())" />
                    </RadzenStack>
                }
                @if (ShowScopeOverrides && _scopeRegistry != null)
                {
                    <RadzenStack Gap="0.25rem">
                        <RadzenLabel Text="Scopes" />
                        <ScopeOverrideEditor AllScopes="_allScopeNames"
                                             Descriptions="_scopeDescriptions"
                                             InheritedScopes="@_scopeRegistry.GetEffectiveScopes(_newAccessLevel, _newRoles, null)"
                                             Overrides="_newScopeOverrides"
                                             OverridesChanged="@(o => _newScopeOverrides = o.ToList())" />
                    </RadzenStack>
                }
                @if (ShowExpiryDatePicker)
                {
                    <RadzenStack Gap="0.25rem">
                        <RadzenLabel Text="Expiry Date" />
                        <RadzenDatePicker @bind-Value="_newExpiryDate" DateFormat="yyyy-MM-dd"
                                          AllowClear="@(!_options.MaxExpiryDays.HasValue)"
                                          Min="@DateTime.UtcNow.Date"
                                          Max="@(_options.MaxExpiryDays.HasValue ? DateTime.UtcNow.AddDays(_options.MaxExpiryDays.Value).Date : DateTime.MaxValue)" />
                    </RadzenStack>
                }
                <RadzenButton Text="Create" Icon="add" Click="@CreateAsync"
                              Disabled="@string.IsNullOrWhiteSpace(_newName)" />
            </RadzenStack>
        </RadzenCard>
    }
}

@code {

    /// <summary>
    /// When true, each row gets a "View audit log" button that opens a dialog scoped to that key
    /// (CallerKeyId pinned). Default false — opt in on Developer pages where the audit log is configured.
    /// </summary>
    [Parameter] public bool ShowAuditLogButton { get; set; }

    /// <summary>
    /// When true (and an <see cref="IScopeRegistry"/> is registered), surfaces per-key <c>ScopeOverrides</c>:
    /// a new column shows current overrides, the create card gets a multi-select, and each row gets an
    /// Edit-Scopes icon button that opens a dialog. Default false — opt in on pages where operators
    /// should manage narrow-scope keys (e.g. Quilt4Net.Server Value Group keys).
    /// </summary>
    [Parameter] public bool ShowScopeOverrides { get; set; }

    /// <summary>
    /// Tag keys to render as chips in the key row. Tags whose <see cref="Tag.Key"/> is listed here
    /// show as a badge per value (e.g. a "Type" key on a combination key renders one chip per type).
    /// All tags — including binding tags not listed here — remain visible in the row's (i) tooltip.
    /// Default: none (tooltip only).
    /// </summary>
    [Parameter] public string[] ChipTagKeys { get; set; } = Array.Empty<string>();

    /// <summary>When true (and an <see cref="IScopeRegistry"/> is registered), shows the per-key effective-scope (i) tooltip. Default true.</summary>
    [Parameter] public bool ShowScopeTooltip { get; set; } = true;

    /// <summary>When true (and an <see cref="ITenantRoleRegistry"/> is registered), allows assigning tenant roles to keys (create card + edit dialog). Default false.</summary>
    [Parameter] public bool ShowRoles { get; set; }

    /// <summary>Shows the "Last used" column (tooltip lists Created + Expiry + Created by; a warning icon appears within 60 days of expiry). Default true.</summary>
    [Parameter] public bool ShowLastUsed { get; set; } = true;

    /// <summary>
    /// Controls the Tags column (chips for keys listed in <see cref="ChipTagKeys"/>, plus an (i) tooltip of all
    /// tags). <c>true</c> = always show, <c>false</c> = always hide, <c>null</c> = auto (show only when at least
    /// one key has tags). Default null (auto).
    /// </summary>
    [Parameter] public bool? ShowTags { get; set; }

    /// <summary>Shows the expiry-date picker on the create card (placed after Scopes). When hidden, new keys use the default expiry (capped by <c>ApiKeyOptions.MaxExpiryDays</c>). Expiry is still shown in the grid (Last used column tooltip + warning) regardless. Default false.</summary>
    [Parameter] public bool ShowExpiryDatePicker { get; set; }

    private bool _apiKeyServiceMissing;
    private IApiKeyManagementService _apiKeyManagementService;
    private bool _hasAccess;
    private bool _teamLoaded;
    private ITeam _selectedTeam;
    private ApiKeyModel[] _keys;
    private ApiKeyOptions _options;
    private IScopeRegistry _scopeRegistry;
    private string[] _allScopeNames = Array.Empty<string>();
    private IReadOnlyDictionary<string, string> _scopeDescriptions = new Dictionary<string, string>();
    private readonly string _apiKeyMask = "**********";
    private readonly AccessLevel[] _accessLevels = Enum.GetValues<AccessLevel>().Where(x => x != AccessLevel.Owner).ToArray();

    private string _newName = "";
    private AccessLevel _newAccessLevel = AccessLevel.User;
    private DateTime? _newExpiryDate;
    private List<string> _newScopeOverrides = new();
    private List<string> _newRoles = new();
    private ITenantRoleRegistry _tenantRoleRegistry;
    private IReadOnlyList<TenantRoleDefinition> _roleDefinitions = Array.Empty<TenantRoleDefinition>();

    protected override async Task OnInitializedAsync()
    {
        _apiKeyManagementService = ServiceProvider.GetService<IApiKeyManagementService>();
        if (_apiKeyManagementService == null)
        {
            _apiKeyServiceMissing = true;
            return;
        }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        // Access is granted by the apikey:manage scope. Cross-team/Developer access comes from the global
        // role→system-scope mapping (o.ConfigureSystemRoles) granting apikey:manage, not a per-component role.
        _hasAccess = user.HasClaim(TeamClaimTypes.Scope, ApiKeyScopes.Manage);
        if (!_hasAccess) { await base.OnInitializedAsync(); return; }

        _scopeRegistry = ServiceProvider.GetService<IScopeRegistry>();
        _allScopeNames = _scopeRegistry?.All.Select(s => s.Name).ToArray() ?? Array.Empty<string>();
        _scopeDescriptions = _scopeRegistry?.All.ToDictionary(s => s.Name, s => s.Description) ?? new Dictionary<string, string>();
        _tenantRoleRegistry = ServiceProvider.GetService<ITenantRoleRegistry>();
        _roleDefinitions = _tenantRoleRegistry?.All ?? Array.Empty<TenantRoleDefinition>();
        _options = ApiKeyOptionsAccessor.Value;
        _newExpiryDate = _options.MaxExpiryDays.HasValue
            ? DateTime.UtcNow.AddDays(_options.MaxExpiryDays.Value).Date
            : null;
        _selectedTeam = await TeamStateService.GetSelectedTeamAsync();
        _teamLoaded = true;
        await ReloadData();
        await base.OnInitializedAsync();
    }

    private async Task ReloadData()
    {
        if (_selectedTeam?.Key == null) return;

        var keys = await _apiKeyManagementService.GetKeysAsync(_selectedTeam.Key).ToArrayAsync();
        _keys = keys
            .Select(x =>
            {
                return new ApiKeyModel
                {
                    Key = x.Key,
                    Name = x.Name,
                    ApiKey = x.ApiKey,
                    VisibleKey = _apiKeyMask,
                    AccessLevel = x.AccessLevel ?? AccessLevel.Administrator,
                    Roles = x.Roles,
                    ScopeOverrides = x.ScopeOverrides,
                    ExpiryDate = x.ExpiryDate,
                    CreatedAt = x.CreatedAt,
                    CreatedBy = x.CreatedBy,
                    LastUsedAt = x.LastUsedAt,
                    Tags = x.Tags ?? Array.Empty<Tag>(),
                };
            }).ToArray();

        StateHasChanged();
    }

    private async Task CreateAsync()
    {
        try
        {
            var scopes = _newScopeOverrides.Count > 0 ? _newScopeOverrides.ToArray() : null;
            var roles = _newRoles.Count > 0 ? _newRoles.ToArray() : null;
            var created = await _apiKeyManagementService.CreateKeyAsync(_selectedTeam.Key, _newName, _newAccessLevel, roles: roles, scopeOverrides: scopes, expiryDate: _newExpiryDate);
            _newName = "";
            _newAccessLevel = AccessLevel.User;
            _newExpiryDate = _options.MaxExpiryDays.HasValue
                ? DateTime.UtcNow.AddDays(_options.MaxExpiryDays.Value).Date
                : null;
            _newScopeOverrides = new List<string>();
            _newRoles = new List<string>();
            await ReloadData();
            await ShowKeyDialogAsync(created);
            NotificationService.Notify(NotificationSeverity.Success, "API key created");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Failed to create key", ex.Message);
        }
    }

    private async Task RefreshAsync(ApiKeyModel context)
    {
        var result = await DialogService.Confirm($"The {context.Name} key will be regenerated.", "Confirm regenerate API key");
        if (result != true) return;

        var refreshed = await _apiKeyManagementService.RefreshKeyAsync(_selectedTeam.Key, context.Key);
        await ReloadData();
        await ShowKeyDialogAsync(refreshed);
    }

    // Reveal the raw key once, immediately after create/regenerate. A dialog (rather than an inline grid
    // reveal) is required because with AutoLockKeys the key is locked on creation, so the reloaded row
    // carries no value to reveal — and this is the only moment the secret exists.
    private async Task ShowKeyDialogAsync(IApiKey key)
    {
        if (key == null || string.IsNullOrEmpty(key.ApiKey)) return;
        await DialogService.OpenAsync<ApiKeyRevealDialog>(
            $"API key — {key.Name}",
            new Dictionary<string, object> { [nameof(ApiKeyRevealDialog.ApiKey)] = key.ApiKey },
            new DialogOptions { Width = "640px", CloseDialogOnOverlayClick = false });
    }

    private string GetKeyScopesText(ApiKeyModel context)
    {
        if (_scopeRegistry == null) return "";

        var accessLevelScopes = _scopeRegistry.GetScopesForAccessLevel(context.AccessLevel);
        var overrides = context.ScopeOverrides ?? Array.Empty<string>();
        var allScopes = _scopeRegistry.GetEffectiveScopes(context.AccessLevel, context.Roles, context.ScopeOverrides);

        var lines = new List<string>();
        foreach (var scope in allScopes.OrderBy(s => s, StringComparer.Ordinal))
        {
            var origin = overrides.Contains(scope) ? "override"
                : accessLevelScopes.Contains(scope) ? "access level"
                : "role";
            lines.Add($"{scope} ({origin})");
        }
        return string.Join("\n", lines);
    }

    private static string GetKeyTagsText(ApiKeyModel context)
        => string.Join("\n", context.Tags.Select(t => $"{t.Key} = {t.Value}"));

    private static string GetKeyDatesText(ApiKeyModel context)
    {
        var created = context.CreatedAt.HasValue ? context.CreatedAt.Value.ToString("yyyy-MM-dd") : "—";
        var expires = context.ExpiryDate.HasValue ? context.ExpiryDate.Value.ToString("yyyy-MM-dd") : "No expiry";
        var by = string.IsNullOrWhiteSpace(context.CreatedBy) ? "System" : context.CreatedBy;
        return $"Created: {created}\nExpires: {expires}\nCreated by: {by}";
    }

    private static bool IsExpiringSoon(ApiKeyModel context)
        => context.ExpiryDate.HasValue && context.ExpiryDate.Value <= DateTime.UtcNow.AddDays(60);

    private bool AnyKeyHasTags() => _keys?.Any(k => k.Tags.Count > 0) ?? false;

    private bool IsKeyVisible(ApiKeyModel context)
    {
        return !string.IsNullOrEmpty(context.VisibleKey) && context.VisibleKey != _apiKeyMask;
    }

    private void OpenRowMenu(MouseEventArgs args, ApiKeyModel context)
    {
        var hasValue = !string.IsNullOrEmpty(context.ApiKey);
        var showEdit = (ShowScopeOverrides && _scopeRegistry != null) || (ShowRoles && _tenantRoleRegistry != null);

        var items = new List<ContextMenuItem>();
        if (hasValue) items.Add(new ContextMenuItem { Text = "Copy", Icon = "content_copy", Value = "copy" });
        if (hasValue && context.VisibleKey == _apiKeyMask) items.Add(new ContextMenuItem { Text = "Show value", Icon = "visibility", Value = "show" });
        if (hasValue && context.VisibleKey != _apiKeyMask) items.Add(new ContextMenuItem { Text = "Hide value", Icon = "visibility_off", Value = "hide" });
        if (ShowAuditLogButton) items.Add(new ContextMenuItem { Text = "Audit log", Icon = "manage_search", Value = "audit" });
        if (showEdit) items.Add(new ContextMenuItem { Text = "Edit roles & scopes", Icon = "tune", Value = "edit" });
        if (hasValue) items.Add(new ContextMenuItem { Text = "Lock", Icon = "lock", Value = "lock" });
        items.Add(new ContextMenuItem { Text = "Refresh", Icon = "refresh", Value = "refresh" });
        if (_options.AdvancedMode) items.Add(new ContextMenuItem { Text = "Delete", Icon = "delete", Value = "delete" });

        ContextMenuService.Open(args, items, async e =>
        {
            ContextMenuService.Close();
            await OnRowActionAsync(context, e.Value as string);
        });
    }

    private async Task OnRowActionAsync(ApiKeyModel context, string action)
    {
        switch (action)
        {
            case "show": context.VisibleKey = context.ApiKey; break;
            case "hide": context.VisibleKey = _apiKeyMask; break;
            case "copy": await CopyToClipboard(context); break;
            case "audit": await OpenAuditLogAsync(context); break;
            case "edit": await OpenEditAsync(context); break;
            case "lock": await LockKeyAsync(context); break;
            case "refresh": await RefreshAsync(context); break;
            case "delete": await DeleteAsync(context); break;
        }
        StateHasChanged();
    }

    private async Task CopyToClipboard(ApiKeyModel context)
    {
        var keyToCopy = IsKeyVisible(context) ? context.VisibleKey : context.ApiKey;
        await Js.InvokeVoidAsync("clipboard.copyText", keyToCopy);
        NotificationService.Notify(new NotificationMessage
        {
            Summary = $"The {context.Name} key has been copied to the clipboard."
        });
    }

    private async Task LockKeyAsync(ApiKeyModel context)
    {
        var result = await DialogService.Confirm($"The {context.Name} key will be locked. After that, it cannot be retrieved.", "Confirm lock API key");
        if (result != true) return;

        await _apiKeyManagementService.LockKeyAsync(_selectedTeam.Key, context.Key);
        await ReloadData();
    }

    private async Task DeleteAsync(ApiKeyModel context)
    {
        var result = await DialogService.Confirm($"Delete API key '{context.Name}'? This cannot be undone.", "Confirm delete");
        if (result != true) return;

        try
        {
            await _apiKeyManagementService.DeleteKeyAsync(_selectedTeam.Key, context.Key);
            await ReloadData();
            NotificationService.Notify(NotificationSeverity.Success, "API key deleted");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Failed to delete key", ex.Message);
        }
    }

    private async Task OpenAuditLogAsync(ApiKeyModel context)
    {
        var pinned = new Audit.AuditPinnedFilter
        {
            CallerKeyId = context.Key,
            CallerType = Service.Audit.AuditCallerType.ApiKey,
        };

        await DialogService.OpenAsync($"Audit log — {context.Name}", _ =>
            @<Tharga.Team.Blazor.Features.Audit.AuditLogView PinnedFilter="@pinned" />,
            new DialogOptions { Width = "90vw", Height = "85vh", Resizable = true, Draggable = true });
    }

    private async Task OpenEditAsync(ApiKeyModel context)
    {
        var showRoles = ShowRoles && _tenantRoleRegistry != null;
        var showScopes = ShowScopeOverrides && _scopeRegistry != null;
        if (!showRoles && !showScopes) return;

        var selectedRoles = (context.Roles ?? Array.Empty<string>()).ToList();
        var selectedScopes = (context.ScopeOverrides ?? Array.Empty<string>()).ToList();

        await DialogService.OpenAsync($"Edit — {context.Name}", ds =>
            @<RadzenStack Gap="1rem" Style="padding: 1rem; min-width: 400px;">
                @if (showRoles)
                {
                    <RadzenLabel Text="Roles" />
                    <RoleEditor Roles="_roleDefinitions"
                                Selected="@(context.Roles ?? Array.Empty<string>())"
                                SelectedChanged="@(r => selectedRoles = r.ToList())"
                                Style="width: 100%;" />
                }
                @if (showScopes)
                {
                    <RadzenLabel Text="Scope Overrides" />
                    <ScopeOverrideEditor AllScopes="_allScopeNames"
                                         Descriptions="_scopeDescriptions"
                                         InheritedScopes="@_scopeRegistry.GetEffectiveScopes(context.AccessLevel, context.Roles, null)"
                                         Overrides="@(context.ScopeOverrides ?? Array.Empty<string>())"
                                         OverridesChanged="@(o => selectedScopes = o.ToList())"
                                         Style="width: 100%;" />
                }
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
                    <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => ds.Close())" />
                    <RadzenButton Text="Save" ButtonStyle="ButtonStyle.Primary"
                                  Click="@(async () => { await SaveEditAsync(context, showRoles ? selectedRoles.ToArray() : null, showScopes ? selectedScopes.ToArray() : null); ds.Close(); })" />
                </RadzenStack>
            </RadzenStack>,
            new DialogOptions { ShowClose = false });
    }

    private async Task SaveEditAsync(ApiKeyModel context, string[] roles, string[] scopes)
    {
        try
        {
            if (roles != null) await _apiKeyManagementService.SetRolesAsync(_selectedTeam.Key, context.Key, roles);
            if (scopes != null) await _apiKeyManagementService.SetScopeOverridesAsync(_selectedTeam.Key, context.Key, scopes);
            await ReloadData();
            NotificationService.Notify(NotificationSeverity.Success, "API key updated");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Failed to update key", ex.Message);
        }
    }

}
