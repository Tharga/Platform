@namespace Tharga.Team.Blazor.Features.Roles
@using System.Security.Claims
@using Microsoft.Extensions.DependencyInjection
@using Tharga.Team.Blazor.Features.Team
@inject IServiceProvider ServiceProvider
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NotificationService NotificationService

@*
    Runtime role administration for the selected team: a team admin (team:manage) creates / edits / deletes
    the team's own custom roles, each granting a chosen subset of the app-registered scopes. Surfaced
    alongside code-registered roles in the member role picker. Requires o.EnableDynamicRoles.
*@

@if (_scopeRegistry == null)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" Variant="Variant.Flat">
        No scopes are configured. Register them via <code>o.ConfigureScopes</code> in Program.cs before defining custom roles.
    </RadzenAlert>
}
else if (_tenantRoleService == null)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" Variant="Variant.Flat">
        Dynamic tenant roles are not enabled. Set <code>o.EnableDynamicRoles = true</code> in <code>AddThargaPlatform</code>.
    </RadzenAlert>
}
else if (!_canManage)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" Variant="Variant.Flat">
        Managing custom roles requires the <code>@TeamScopes.Manage</code> scope on this team.
    </RadzenAlert>
}
else if (string.IsNullOrEmpty(_teamKey))
{
    <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" Variant="Variant.Flat">No team selected.</RadzenAlert>
}
else
{
    <RadzenDataGrid @ref="_grid" Data="@_model.Roles" TItem="EditableTenantRole" AllowSorting="false" AllowFiltering="false">
        <Columns>
            <RadzenDataGridColumn Title="Name" Width="220px">
                <Template>
                    <RadzenTextBox @bind-Value="context.Name" Placeholder="Role name" Style="width: 100%;" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Title="Description" Visible="@ShowDescription">
                <Template>
                    <RadzenTextBox @bind-Value="context.Description" Placeholder="Optional description" Style="width: 100%;" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Title="Scopes" Width="320px">
                <Template>
                    <RadzenDropDown TValue="IEnumerable<string>"
                                    Multiple="true"
                                    AllowClear="true"
                                    Chips="true"
                                    Data="@_allScopeNames"
                                    Value="@context.Scopes"
                                    ValueChanged="@(v => context.Scopes = (v ?? Enumerable.Empty<string>()).ToList())"
                                    Placeholder="Select scopes..."
                                    Style="width: 100%;" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Title="" Width="60px" Sortable="false" Filterable="false">
                <Template>
                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat" Size="ButtonSize.Small"
                                  Click="@(() => RemoveRole(context))" title="Delete role" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>

    @if (_errors.Count > 0)
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" class="rz-mt-2">
            <ul style="margin: 0; padding-left: 1.2rem;">
                @foreach (var error in _errors)
                {
                    <li>@error</li>
                }
            </ul>
        </RadzenAlert>
    }

    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" class="rz-mt-3">
        <RadzenButton Icon="add" Text="Add role" ButtonStyle="ButtonStyle.Secondary" Variant="Variant.Flat"
                      Size="ButtonSize.Small" Click="@AddRole" />
        <RadzenButton Icon="save" Text="Save" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small"
                      IsBusy="@_saving" Disabled="@_saving" Click="@SaveAsync" />
    </RadzenStack>
}

@code {
    /// <summary>Show the Description column/input. Default true.</summary>
    [Parameter] public bool ShowDescription { get; set; } = true;

    private IScopeRegistry _scopeRegistry;
    private ITenantRoleRegistry _roleRegistry;
    private ITenantRoleService _tenantRoleService;
    private ITeamManagementService _managementService;
    private ITeamService _teamService;
    private ITeamStateService _teamStateService;

    private RadzenDataGrid<EditableTenantRole> _grid;
    private readonly TenantRoleManagerModel _model = new();
    private string _teamKey;
    private bool _canManage;
    private string[] _allScopeNames = [];
    private IReadOnlyList<string> _codeRoleNames = [];
    private IReadOnlyList<string> _errors = [];
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        _scopeRegistry = ServiceProvider.GetService<IScopeRegistry>();
        _roleRegistry = ServiceProvider.GetService<ITenantRoleRegistry>();
        _tenantRoleService = ServiceProvider.GetService<ITenantRoleService>();
        _managementService = ServiceProvider.GetService<ITeamManagementService>();
        _teamService = ServiceProvider.GetService<ITeamService>();
        _teamStateService = ServiceProvider.GetService<ITeamStateService>();

        if (_scopeRegistry != null)
            _allScopeNames = _scopeRegistry.All.Select(s => s.Name).OrderBy(s => s, StringComparer.Ordinal).ToArray();
        _codeRoleNames = _roleRegistry?.All.Select(r => r.Name).ToList() ?? (IReadOnlyList<string>)[];

        var principal = await GetCurrentPrincipalAsync();
        _canManage = principal?.HasClaim(TeamClaimTypes.Scope, TeamScopes.Manage) ?? false;

        var team = _teamStateService != null ? await _teamStateService.GetSelectedTeamAsync() : null;
        _teamKey = team?.Key;

        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _errors = [];
        if (string.IsNullOrEmpty(_teamKey) || _teamService == null) return;

        var roles = await _teamService.GetTeamCustomRolesAsync(_teamKey);
        _model.Load(roles);
        if (_grid != null) await _grid.Reload();
    }

    private async Task AddRole()
    {
        _model.AddNew();
        if (_grid != null) await _grid.Reload();
    }

    private async Task RemoveRole(EditableTenantRole role)
    {
        _model.Remove(role);
        if (_grid != null) await _grid.Reload();
    }

    private async Task SaveAsync()
    {
        _errors = _model.Validate(_codeRoleNames);
        if (_errors.Count > 0) return;

        _saving = true;
        try
        {
            await _managementService.SetTeamCustomRolesAsync(_teamKey, _model.ToDefinitions());
            NotificationService.Notify(NotificationSeverity.Success, "Custom roles saved.");
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _errors = [ex.Message];
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task<ClaimsPrincipal> GetCurrentPrincipalAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            return authState?.User;
        }
        catch { return null; }
    }
}
