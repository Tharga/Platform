@using Tharga.Team
@inject IIconResolver IconResolver

@if (_url != null)
{
    <img src="@_url" alt="@_alt" title="@_alt"
         style="width:@Size;height:@Size;border-radius:50%;object-fit:cover;display:inline-block;vertical-align:middle;" />
}
else
{
    <span title="@_alt"
          style="width:@Size;height:@Size;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;background:var(--rz-primary-lighter,#e0e7ff);color:var(--rz-primary,#3730a3);font-size:calc(@Size * 0.4);font-weight:600;vertical-align:middle;">
        @_initials
    </span>
}

@code {
    /// <summary>A user to render the avatar for. When set, takes precedence over the individual fields.</summary>
    [Parameter] public IUser User { get; set; }

    /// <summary>The user's key (used with the individual-field form).</summary>
    [Parameter] public string UserKey { get; set; }

    /// <summary>Display name (for the initials fallback).</summary>
    [Parameter] public string Name { get; set; }

    /// <summary>Email (used by the Gravatar fallback).</summary>
    [Parameter] public string EMail { get; set; }

    /// <summary>Reference of an explicitly-uploaded icon, if any.</summary>
    [Parameter] public string IconReference { get; set; }

    /// <summary>CSS size (width and height) of the avatar. Default 40px.</summary>
    [Parameter] public string Size { get; set; } = "40px";

    private string _url;
    private string _initials = "?";
    private string _alt = "";

    protected override async Task OnParametersSetAsync()
    {
        var key = User?.Key ?? UserKey;
        var email = User?.EMail ?? EMail;
        var iconReference = User?.Icon ?? IconReference;
        var display = User?.Name ?? Name ?? email;

        if (string.IsNullOrEmpty(email) && string.IsNullOrEmpty(iconReference) && string.IsNullOrEmpty(display))
        {
            _url = null;
            _initials = "?";
            _alt = "";
            return;
        }

        _alt = display;
        _initials = IconInitials.From(display);

        var subject = new IconSubject
        {
            Kind = IconKind.User,
            Key = key,
            Name = display,
            EMail = email,
            IconReference = iconReference
        };

        var image = await IconResolver.ResolveAsync(subject);
        _url = image?.Url;
    }
}
