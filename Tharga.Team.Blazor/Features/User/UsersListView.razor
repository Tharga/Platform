@using Microsoft.Extensions.DependencyInjection
@typeparam TMember where TMember : class, Tharga.Team.ITeamMember
@inject ITeamService TeamService
@inject IUserService UserService
@inject IUserManagementService UserManagementService
@inject IServiceProvider ServiceProvider
@inject AuthenticationStateProvider AuthStateProvider
@inject DialogService DialogService
@inject NotificationService NotificationService

@if (!_canAdminister)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" Variant="Variant.Flat" AllowClose="false" class="rz-mt-2">
        Viewing users requires the <b>@SystemUserScopes.Manage</b> system scope.
    </RadzenAlert>
}
else if (_loaded)
{
    @if (_showDirectory)
    {
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" class="rz-mb-3 rz-mt-2">
            <RadzenButton Text="Verify all" Icon="how_to_reg" ButtonStyle="ButtonStyle.Light" Click="@VerifyAllAsync" Disabled="@_verifying" />
        </RadzenStack>
    }
    <RadzenDataGrid Data="@_allUsers" TItem="UserViewModel" AllowSorting="true" AllowPaging="true" PageSize="10"
                    AllowFiltering="true" FilterMode="FilterMode.Simple" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive">
        <Columns>
            <RadzenDataGridColumn Title="" Width="66px" Sortable="false" Filterable="false">
                <Template>
                    <UserAvatar EMail="@context.EMail" IconReference="@context.Icon" Name="@context.Name" UserKey="@context.Key" Size="32px" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Title="Name" Property="Name" />
            <RadzenDataGridColumn Title="Email" Property="EMail" />
            <RadzenDataGridColumn Title="Teams" Property="@nameof(UserViewModel.TeamCount)" Filterable="false" />
            <RadzenDataGridColumn Title="Last seen" Property="@nameof(UserViewModel.LastSeen)" Filterable="false">
                <Template>
                    <DateTimeView Date="@context.LastSeen" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Title="" Width="200px" Sortable="false" Filterable="false">
                <Template>
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                        @if (_showDirectory && context.DirectoryStatus != null)
                        {
                            <RadzenBadge BadgeStyle="@(Enum.Parse<BadgeStyle>(DirectoryStatusBadge.Style(context.DirectoryStatus.Value)))"
                                         Variant="Variant.Flat" Text="@DirectoryStatusBadge.Text(context.DirectoryStatus.Value)" />
                        }
                        <RadzenSplitButton Text="View" Icon="visibility" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                           Click="@(item => OnUserActionAsync(item, context))">
                            <ChildContent>
                                @if (_showDirectory)
                                {
                                    <RadzenSplitButtonItem Text="Verify" Value="@VerifyAction" Icon="person_search" />
                                }
                                @ActionItems
                                <RadzenSplitButtonItem Text="Delete" Value="@DeleteAction" Icon="delete" />
                            </ChildContent>
                        </RadzenSplitButton>
                        @if (ActionsTemplate != null)
                        {
                            @ActionsTemplate(context)
                        }
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>

    @if (_selectedUser != null)
    {
        <RadzenCard class="rz-mt-3">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" class="rz-mb-2">
                <UserAvatar EMail="@_selectedUser.EMail" IconReference="@_selectedUser.Icon" Name="@_selectedUser.Name" UserKey="@_selectedUser.Key" Size="48px" />
                <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                    <RadzenText TextStyle="TextStyle.Subtitle1"><strong>@(_selectedUser.Name ?? _selectedUser.EMail)</strong></RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption">@_selectedUser.EMail</RadzenText>
                </RadzenStack>
            </RadzenStack>
            <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-1">Team memberships</RadzenText>
            <RadzenDataGrid Data="@_selectedUser.Teams" TItem="UserTeamInfo" AllowSorting="true">
                <Columns>
                    <RadzenDataGridColumn Title="Team" Property="TeamName" />
                    <RadzenDataGridColumn Title="Role" Property="AccessLevel" Width="120px" />
                    <RadzenDataGridColumn Title="State" Property="State" Width="100px" />
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>
    }
}
else
{
    <Loading />
}

@code {
    /// <summary>
    /// Optional template rendered after the built-in split button in each user row's action column.
    /// Use to inject row-level actions (edit, custom links) without forking the component.
    /// </summary>
    [Parameter] public RenderFragment<UserViewModel> ActionsTemplate { get; set; }

    /// <summary>
    /// Optional extra items appended to each row's split-button dropdown — supply
    /// <c>RadzenSplitButtonItem</c> components with distinct <c>Value</c>s. Clicks are delivered via
    /// <see cref="ActionInvoked"/> with the item's Value and the row's user.
    /// </summary>
    [Parameter] public RenderFragment ActionItems { get; set; }

    /// <summary>Raised when a consumer-supplied split-button item (<see cref="ActionItems"/>) is clicked.</summary>
    [Parameter] public EventCallback<UserRowAction> ActionInvoked { get; set; }

    private const string VerifyAction = "verify";
    private const string DeleteAction = "delete";

    private bool _loaded;
    private bool _canAdminister = true;
    private bool _showDirectory;
    private bool _verifying;
    private IUser[] _users;
    private ITeam<TMember>[] _teams;

    private List<UserViewModel> _allUsers = new();
    private UserViewModel _selectedUser;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var hasUsersManage = authState.User.HasClaim(TeamClaimTypes.Scope, SystemUserScopes.Manage);
        var directoryRegistered = ServiceProvider.GetService<IUserDirectoryService>() != null;
        _canAdminister = UserAdminGate.CanAdministerUsers(hasUsersManage);
        _showDirectory = UserAdminGate.ShowDirectoryFeatures(hasUsersManage, directoryRegistered);

        if (_canAdminister)
        {
            await LoadDataAsync();
            _loaded = true;
        }

        await base.OnInitializedAsync();
    }

    private async Task LoadDataAsync()
    {
        _users = await UserService.GetAsync().ToArrayAsync();
        _teams = await TeamService.GetTeamsAsync<TMember>().ToArrayAsync();

        BuildViewModels();
    }

    private void BuildViewModels()
    {
        var teamLookup = _teams
            .Where(t => t.Members != null)
            .SelectMany(t => t.Members.Select(m => new { Team = t, Member = m }))
            .GroupBy(x => new { TeamKey = x.Team.Key, MemberKey = x.Member.Key })
            .Select(g => g.First())
            .ToLookup(x => x.Member.Key);

        _allUsers = _users.Select(u => new UserViewModel
        {
            Key = u.Key,
            Name = u.Name ?? TeamServiceBase.ResolveDisplayName(u),
            EMail = u.EMail,
            Icon = u.Icon,
            LastSeen = u.LastSeen,
            TeamCount = teamLookup[u.Key].Count(),
            Teams = teamLookup[u.Key].Select(x => new UserTeamInfo
            {
                TeamKey = x.Team.Key,
                TeamName = x.Team.Name,
                AccessLevel = x.Member.AccessLevel,
                State = x.Member.State
            }).ToArray()
        }).OrderBy(u => u.Name).ToList();
    }

    private async Task OnUserActionAsync(RadzenSplitButtonItem item, UserViewModel user)
    {
        switch (item?.Value)
        {
            case null:
                ToggleDetails(user);
                break;
            case VerifyAction:
                await VerifyUserAsync(user);
                break;
            case DeleteAction:
                await DeleteUserAsync(user);
                break;
            default:
                await ActionInvoked.InvokeAsync(new UserRowAction(item.Value, user));
                break;
        }
    }

    private void ToggleDetails(UserViewModel user)
    {
        _selectedUser = _selectedUser?.Key == user.Key ? null : user;
    }

    private async Task VerifyUserAsync(UserViewModel user)
    {
        try
        {
            var result = await UserManagementService.VerifyUserAsync(user.Key);
            user.DirectoryStatus = result.Status;
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Verification failed", ex.Message);
        }
    }

    private async Task VerifyAllAsync()
    {
        _verifying = true;
        try
        {
            await foreach (var item in UserManagementService.VerifyAllAsync())
            {
                var row = _allUsers.FirstOrDefault(x => x.Key == item.UserKey);
                if (row != null) row.DirectoryStatus = item.Result.Status;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Verification failed", ex.Message);
        }
        finally
        {
            _verifying = false;
        }
    }

    private async Task DeleteUserAsync(UserViewModel user)
    {
        var dialogResult = await DialogService.OpenAsync<DeleteUserDialog>("Delete user",
            new Dictionary<string, object>
            {
                { nameof(DeleteUserDialog.UserName), user.Name ?? user.EMail },
                { nameof(DeleteUserDialog.UserKey), user.Key },
                { nameof(DeleteUserDialog.ShowDirectoryOption), _showDirectory }
            });
        if (dialogResult is not bool alsoDeleteFromDirectory) return;

        try
        {
            var result = await UserManagementService.DeleteUserAsync(user.Key, alsoDeleteFromDirectory);
            if (result.DirectoryError != null)
            {
                NotificationService.Notify(NotificationSeverity.Warning, "User deleted locally",
                    $"Directory delete did not complete: {result.DirectoryError}");
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Success, "User deleted",
                    $"Removed from {result.RemovedTeamCount} team(s){(result.DirectoryDeleted ? " and the directory" : "")}.");
            }

            if (_selectedUser?.Key == user.Key) _selectedUser = null;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Delete failed", ex.Message);
        }
    }
}
