@inject DialogService DialogService
@inject IUserManagementService UserManagementService

@*
    Confirmation for the user-delete flow. The local delete (all team memberships + the user record)
    always happens; deleting from the external directory is an explicit opt-in, off by default, because
    it removes the account org-wide — not just from this application. When a directory is registered,
    the dialog verifies the user against it on open, so the text states whether the account still
    exists there — and the opt-in is not offered when there is nothing to delete (already gone) or no
    directory match.
*@
<RadzenStack Gap="1rem">
    <RadzenText TextStyle="TextStyle.Body1">
        Delete <b>@UserName</b>? The user is removed from every team and the user record is deleted.
        This cannot be undone.
    </RadzenText>

    @if (ShowDirectoryOption)
    {
        @if (_checking)
        {
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenProgressBarCircular ProgressBarStyle="ProgressBarStyle.Primary" Mode="ProgressBarMode.Indeterminate" Style="width: 20px; height: 20px;" ShowValue="false" />
                <RadzenText TextStyle="TextStyle.Caption">Checking the directory…</RadzenText>
            </RadzenStack>
        }
        else if (_directoryStatus == DirectoryUserStatus.NotFound)
        {
            <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">
                This user no longer exists in the directory — the account has already been deleted there.
                Only the local user is removed.
            </RadzenAlert>
        }
        else if (_directoryStatus == DirectoryUserStatus.NotLinked)
        {
            <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">
                This user could not be matched to a directory account, so there is nothing to delete in
                the directory. Only the local user is removed.
            </RadzenAlert>
        }
        else
        {
            @if (_directoryStatus == DirectoryUserStatus.Disabled)
            {
                <RadzenText TextStyle="TextStyle.Caption">The user exists in the directory, but the account is disabled.</RadzenText>
            }
            else if (_directoryStatus == DirectoryUserStatus.Found)
            {
                <RadzenText TextStyle="TextStyle.Caption">The user exists in the directory.</RadzenText>
            }
            else if (_checkError != null)
            {
                <RadzenText TextStyle="TextStyle.Caption">Directory check failed: @_checkError</RadzenText>
            }

            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenCheckBox @bind-Value="_alsoDeleteFromDirectory" Name="alsoDeleteFromDirectory" TValue="bool" />
                <RadzenLabel Text="Also delete from the external directory" Component="alsoDeleteFromDirectory" />
            </RadzenStack>

            @if (_alsoDeleteFromDirectory)
            {
                <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">
                    Deleting from the directory removes the account <b>organization-wide</b>, affecting every
                    application it signs in to — not just this one. An administrator can restore it for a
                    limited time (30 days in Microsoft Entra ID).
                </RadzenAlert>
            }
        }
    }

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
        <RadzenButton Text="Delete" ButtonStyle="ButtonStyle.Danger" Click="@(() => DialogService.Close(_alsoDeleteFromDirectory))" />
        <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Base" Variant="Variant.Flat" Click="@(() => DialogService.Close(null))" />
    </RadzenStack>
</RadzenStack>

@code {
    /// <summary>Display name of the user about to be deleted.</summary>
    [Parameter] public string UserName { get; set; }

    /// <summary>Key of the user about to be deleted — used to verify against the directory on open.</summary>
    [Parameter] public string UserKey { get; set; }

    /// <summary>Whether directory features apply (a directory service is registered).</summary>
    [Parameter] public bool ShowDirectoryOption { get; set; }

    private bool _alsoDeleteFromDirectory;
    private bool _checking;
    private DirectoryUserStatus? _directoryStatus;
    private string _checkError;

    protected override async Task OnInitializedAsync()
    {
        if (ShowDirectoryOption && !string.IsNullOrEmpty(UserKey))
        {
            _checking = true;
            try
            {
                var result = await UserManagementService.VerifyUserAsync(UserKey);
                _directoryStatus = result?.Status;
            }
            catch (Exception ex)
            {
                _checkError = ex.Message;
            }
            finally
            {
                _checking = false;
            }
        }

        await base.OnInitializedAsync();
    }
}
