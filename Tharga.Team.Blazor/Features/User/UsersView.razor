@using Microsoft.AspNetCore.Authorization
@using Microsoft.Extensions.DependencyInjection
@using Tharga.Team
@typeparam TMember where TMember : class, Tharga.Team.ITeamMember
@attribute [Authorize(Roles = "Developer")]
@inject IServiceProvider ServiceProvider
@inject AuthenticationStateProvider AuthStateProvider

<RadzenTabs>
    <Tabs>
        <RadzenTabsItem Text="Users">
            <UsersListView TMember="TMember" ActionsTemplate="ActionsTemplate" />
        </RadzenTabsItem>
        <RadzenTabsItem Text="Teams">
            <TeamsListView TMember="TMember" />
        </RadzenTabsItem>
        @if (_showDirectoryTab)
        {
            <RadzenTabsItem Text="Directory only">
                <DirectoryOnlyUsersView />
            </RadzenTabsItem>
        }
    </Tabs>
</RadzenTabs>

@code {
    /// <summary>
    /// Optional template for extra row-level actions in the Users tab, passed through to
    /// <see cref="UsersListView{TMember}"/>. Lets a host keep this packaged tabbed view (including the
    /// directory-only tab) while injecting its own actions.
    /// </summary>
    [Parameter] public RenderFragment<UserViewModel> ActionsTemplate { get; set; }

    private bool _showDirectoryTab;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var hasUsersManage = authState.User.HasClaim(TeamClaimTypes.Scope, SystemUserScopes.Manage);
        var directoryRegistered = ServiceProvider.GetService<IUserDirectoryService>() != null;
        _showDirectoryTab = UserAdminGate.ShowDirectoryFeatures(hasUsersManage, directoryRegistered);

        await base.OnInitializedAsync();
    }
}
