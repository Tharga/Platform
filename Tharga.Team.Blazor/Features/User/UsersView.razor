@using Microsoft.AspNetCore.Authorization
@using Tharga.Team
@typeparam TMember where TMember : class, Tharga.Team.ITeamMember
@attribute [Authorize(Roles = "Developer")]
@inject ITeamService TeamService
@inject IUserService UserService

@if (_teams == null)
{
    <Loading />
}
else
{
    <RadzenTabs>
        <Tabs>
            <RadzenTabsItem Text="Users">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" Gap="0.5rem" class="rz-mb-3 rz-mt-2">
                    <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                        <RadzenLabel Text="Search" />
                        <RadzenTextBox @bind-Value="_userSearch" Placeholder="Name or email..." Change="@OnUserSearchChanged" Style="width: 250px;" />
                    </RadzenStack>
                </RadzenStack>
                <RadzenDataGrid Data="@_filteredUsers" TItem="UserViewModel" AllowSorting="true" AllowPaging="true" PageSize="10"
                                RowSelect="@OnUserSelected" Style="cursor: pointer;">
                    <Columns>
                        <RadzenDataGridColumn Title="" Width="66px" Sortable="false" Filterable="false">
                            <Template>
                                <RadzenGravatar Email="@context.EMail" Style="width: 32px; height: 32px;" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn Title="Name" Property="Name" />
                        <RadzenDataGridColumn Title="Email" Property="EMail" />
                        <RadzenDataGridColumn Title="Teams" Sortable="false">
                            <Template>
                                @context.TeamCount
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>

                @if (_selectedUser != null)
                {
                    <RadzenCard class="rz-mt-3">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" class="rz-mb-2">
                            <RadzenGravatar Email="@_selectedUser.EMail" Style="width: 48px; height: 48px;" />
                            <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                                <RadzenText TextStyle="TextStyle.Subtitle1"><strong>@(_selectedUser.Name ?? _selectedUser.EMail)</strong></RadzenText>
                                <RadzenText TextStyle="TextStyle.Caption">@_selectedUser.EMail</RadzenText>
                            </RadzenStack>
                        </RadzenStack>
                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-1">Team memberships</RadzenText>
                        <RadzenDataGrid Data="@_selectedUser.Teams" TItem="UserTeamInfo" AllowSorting="true">
                            <Columns>
                                <RadzenDataGridColumn Title="Team" Property="TeamName" />
                                <RadzenDataGridColumn Title="Role" Property="AccessLevel" Width="120px" />
                                <RadzenDataGridColumn Title="State" Property="State" Width="100px" />
                            </Columns>
                        </RadzenDataGrid>
                    </RadzenCard>
                }
            </RadzenTabsItem>

            <RadzenTabsItem Text="Teams">
                <RadzenDataGrid Data="@_teamViewModels" TItem="TeamViewModel" AllowSorting="true" AllowPaging="true" PageSize="10"
                                RowSelect="@OnTeamSelected" Style="cursor: pointer;">
                    <Columns>
                        <RadzenDataGridColumn Title="Name" Property="Name" />
                        <RadzenDataGridColumn Title="Members" Property="MemberCount" Width="100px" />
                    </Columns>
                </RadzenDataGrid>

                @if (_selectedTeam != null)
                {
                    <RadzenCard class="rz-mt-3">
                        <RadzenText TextStyle="TextStyle.Subtitle1"><strong>@_selectedTeam.Name</strong></RadzenText>
                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-1">Members</RadzenText>
                        <RadzenDataGrid Data="@_selectedTeam.Members" TItem="TeamMemberInfo" AllowSorting="true">
                            <Columns>
                                <RadzenDataGridColumn Title="" Width="50px" Sortable="false">
                                    <Template>
                                        <RadzenGravatar Email="@context.EMail" Style="width: 32px; height: 32px;" />
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn Title="Name" Property="Name" />
                                <RadzenDataGridColumn Title="Email" Property="EMail" />
                                <RadzenDataGridColumn Title="Role" Property="AccessLevel" Width="120px" />
                                <RadzenDataGridColumn Title="State" Property="State" Width="100px" />
                                <RadzenDataGridColumn Title="Last seen" Sortable="true" Width="150px">
                                    <Template>
                                        <DateTimeView Date="@context.LastSeen" />
                                    </Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                    </RadzenCard>
                }
            </RadzenTabsItem>
        </Tabs>
    </RadzenTabs>
}

@code {
    private IUser[] _users;
    private ITeam<TMember>[] _teams;

    private string _userSearch = "";
    private List<UserViewModel> _allUsers = new();
    private List<UserViewModel> _filteredUsers = new();
    private List<TeamViewModel> _teamViewModels = new();
    private UserViewModel _selectedUser;
    private TeamViewModel _selectedTeam;

    protected override async Task OnInitializedAsync()
    {
        _users = await UserService.GetAsync().ToArrayAsync();
        _teams = await TeamService.GetTeamsAsync<TMember>().ToArrayAsync();

        BuildViewModels();

        await base.OnInitializedAsync();
    }

    private void BuildViewModels()
    {
        var teamLookup = _teams
            .Where(t => t.Members != null)
            .SelectMany(t => t.Members.Select(m => new { Team = t, Member = m }))
            .ToLookup(x => x.Member.Key);

        _allUsers = _users.Select(u => new UserViewModel
        {
            Key = u.Key,
            Name = u.Name ?? TeamServiceBase.ResolveDisplayName(u),
            EMail = u.EMail,
            TeamCount = teamLookup[u.Key].Count(),
            Teams = teamLookup[u.Key].Select(x => new UserTeamInfo
            {
                TeamName = x.Team.Name,
                AccessLevel = x.Member.AccessLevel,
                State = x.Member.State
            }).ToArray()
        }).OrderBy(u => u.Name).ToList();

        _filteredUsers = _allUsers;

        _teamViewModels = _teams.Select(t => new TeamViewModel
        {
            Key = t.Key,
            Name = t.Name,
            MemberCount = t.Members?.Length ?? 0,
            Members = (t.Members ?? []).Select(m =>
            {
                var user = _users.FirstOrDefault(u => u.Key == m.Key);
                return new TeamMemberInfo
                {
                    Name = m.Name ?? user?.Name ?? TeamServiceBase.ResolveDisplayName(user),
                    EMail = user?.EMail ?? m.Invitation?.EMail,
                    AccessLevel = m.AccessLevel,
                    State = m.State,
                    LastSeen = m.LastSeen
                };
            }).ToArray()
        }).OrderBy(t => t.Name).ToList();
    }

    private void OnUserSearchChanged()
    {
        if (string.IsNullOrWhiteSpace(_userSearch))
        {
            _filteredUsers = _allUsers;
        }
        else
        {
            var search = _userSearch.ToLowerInvariant();
            _filteredUsers = _allUsers
                .Where(u => (u.Name?.ToLowerInvariant().Contains(search) ?? false)
                          || (u.EMail?.ToLowerInvariant().Contains(search) ?? false))
                .ToList();
        }
        _selectedUser = null;
    }

    private void OnUserSelected(UserViewModel user)
    {
        _selectedUser = _selectedUser?.Key == user.Key ? null : user;
    }

    private void OnTeamSelected(TeamViewModel team)
    {
        _selectedTeam = _selectedTeam?.Key == team.Key ? null : team;
    }

    private record UserViewModel
    {
        public string Key { get; init; }
        public string Name { get; init; }
        public string EMail { get; init; }
        public int TeamCount { get; init; }
        public UserTeamInfo[] Teams { get; init; }
    }

    private record UserTeamInfo
    {
        public string TeamName { get; init; }
        public AccessLevel AccessLevel { get; init; }
        public MembershipState? State { get; init; }
    }

    private record TeamViewModel
    {
        public string Key { get; init; }
        public string Name { get; init; }
        public int MemberCount { get; init; }
        public TeamMemberInfo[] Members { get; init; }
    }

    private record TeamMemberInfo
    {
        public string Name { get; init; }
        public string EMail { get; init; }
        public AccessLevel AccessLevel { get; init; }
        public MembershipState? State { get; init; }
        public DateTime? LastSeen { get; init; }
    }
}
