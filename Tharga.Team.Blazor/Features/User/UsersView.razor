@using Microsoft.AspNetCore.Authorization
@using Tharga.Team
@typeparam TMember where TMember : class, Tharga.Team.ITeamMember
@attribute [Authorize(Roles = "Developer")]

<RadzenTabs>
    <Tabs>
        <RadzenTabsItem Text="Users">
            <UsersListView TMember="TMember" />
        </RadzenTabsItem>
        <RadzenTabsItem Text="Teams">
            <TeamsListView TMember="TMember" />
        </RadzenTabsItem>
    </Tabs>
</RadzenTabs>
