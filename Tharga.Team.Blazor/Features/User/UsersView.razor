@using Microsoft.Extensions.DependencyInjection
@using Tharga.Team
@typeparam TMember where TMember : class, Tharga.Team.ITeamMember
@inject IServiceProvider ServiceProvider
@inject AuthenticationStateProvider AuthStateProvider

@*
    No [Authorize] attribute here: it is inert on a non-page component and invited false confidence.
    Access is enforced where it holds — the service layer requires users:manage for every read/write
    these tabs perform, and the child views render a friendly notice without it. Hosts should still
    [Authorize] the page that embeds this component.
*@

<RadzenTabs>
    <Tabs>
        <RadzenTabsItem Text="Users">
            <UsersListView TMember="TMember" ActionsTemplate="ActionsTemplate" ActionItems="ActionItems" ActionInvoked="ActionInvoked" />
        </RadzenTabsItem>
        <RadzenTabsItem Text="Teams">
            <TeamsListView TMember="TMember" />
        </RadzenTabsItem>
        @if (_showDirectoryTab)
        {
            <RadzenTabsItem Text="Users in directory only">
                <DirectoryOnlyUsersView />
            </RadzenTabsItem>
        }
    </Tabs>
</RadzenTabs>

@code {
    /// <summary>
    /// Optional template for extra row-level actions in the Users tab, passed through to
    /// <see cref="UsersListView{TMember}"/>. Lets a host keep this packaged tabbed view (including the
    /// directory-only tab) while injecting its own actions.
    /// </summary>
    [Parameter] public RenderFragment<UserViewModel> ActionsTemplate { get; set; }

    /// <summary>
    /// Optional extra items for each user row's split-button dropdown (supply
    /// <c>RadzenSplitButtonItem</c> components), passed through to <see cref="UsersListView{TMember}"/>.
    /// Clicks arrive via <see cref="ActionInvoked"/>.
    /// </summary>
    [Parameter] public RenderFragment ActionItems { get; set; }

    /// <summary>Raised when a consumer-supplied split-button item (<see cref="ActionItems"/>) is clicked.</summary>
    [Parameter] public EventCallback<UserRowAction> ActionInvoked { get; set; }

    private bool _showDirectoryTab;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var hasUsersManage = authState.User.HasClaim(TeamClaimTypes.Scope, SystemUserScopes.Manage);
        var directoryRegistered = ServiceProvider.GetService<IUserDirectoryService>() != null;
        _showDirectoryTab = UserAdminGate.ShowDirectoryFeatures(hasUsersManage, directoryRegistered);

        await base.OnInitializedAsync();
    }
}
