@using System.Net.Http
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Options
@using Tharga.Team
@using Tharga.Team.Blazor.Framework
@inject IUserService UserService
@inject IHttpClientFactory HttpClientFactory
@inject IOptions<IconOptions> IconOptions
@inject DialogService DialogService
@inject NotificationService NotificationService

@*
    Sets the current user's own icon (self-service) from a file upload or an image URL, or removes it —
    an alternative to the Gravatar fallback. Goes through IUserService.SetOwnIconAsync / ClearOwnIconAsync
    and the pluggable IIconStore.
*@
<RadzenStack Gap="1rem">
    <RadzenText TextStyle="TextStyle.Body2">Upload an image, or provide an image URL to download. Maximum @_maxKb KB. This replaces your Gravatar image.</RadzenText>

    <RadzenStack Gap="0.25rem">
        <RadzenLabel Text="Upload a file" />
        <InputFile OnChange="OnFileSelected" accept="image/*" disabled="@_busy" />
    </RadzenStack>

    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" Gap="0.5rem">
        <RadzenStack Gap="0.25rem" Style="flex:1;">
            <RadzenLabel Text="…or image URL" />
            <RadzenTextBox @bind-Value="_url" Placeholder="https://…/photo.png" Style="width:100%;" Disabled="@_busy" />
        </RadzenStack>
        <RadzenButton Text="Download" Icon="download" Click="OnFetchUrl" Disabled="@(_busy || string.IsNullOrWhiteSpace(_url))" />
    </RadzenStack>

    @if (_busy)
    {
        <RadzenProgressBarCircular ProgressBarStyle="ProgressBarStyle.Primary" Mode="ProgressBarMode.Indeterminate" Style="width:24px;height:24px;" ShowValue="false" />
    }

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
        <div>
            <RadzenButton Text="Use Gravatar" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat" Click="OnRemove" Visible="@HasIcon" Disabled="@_busy" title="Remove the uploaded image and fall back to Gravatar" />
        </div>
        <RadzenButton Text="Close" ButtonStyle="ButtonStyle.Base" Variant="Variant.Flat" Click="@(() => DialogService.Close(_changed))" />
    </RadzenStack>
</RadzenStack>

@code {
    /// <summary>Whether the user currently has an uploaded icon (controls the Use-Gravatar button).</summary>
    [Parameter] public bool HasIcon { get; set; }

    private string _url;
    private bool _busy;
    private bool _changed;
    private int _maxKb;

    protected override void OnInitialized() => _maxKb = IconOptions.Value.MaxBytes / 1024;

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        _busy = true;
        try
        {
            var max = IconOptions.Value.MaxBytes;
            using var stream = new MemoryStream();
            await file.OpenReadStream(max + 1).CopyToAsync(stream);
            await SaveAsync(stream.ToArray(), file.ContentType);
        }
        catch (Exception ex) { NotifyError(ex); }
        finally { _busy = false; }
    }

    private async Task OnFetchUrl()
    {
        if (string.IsNullOrWhiteSpace(_url)) return;

        _busy = true;
        try
        {
            var client = HttpClientFactory.CreateClient(ThargaPlatformRegistration.IconHttpClientName);
            using var response = await client.GetAsync(_url);
            response.EnsureSuccessStatusCode();
            var contentType = response.Content.Headers.ContentType?.MediaType ?? "application/octet-stream";
            var bytes = await response.Content.ReadAsByteArrayAsync();
            await SaveAsync(bytes, contentType);
        }
        catch (Exception ex) { NotifyError(ex); }
        finally { _busy = false; }
    }

    private async Task SaveAsync(byte[] data, string contentType)
    {
        await UserService.SetOwnIconAsync(data, contentType);
        _changed = true;
        NotificationService.Notify(NotificationSeverity.Success, "Profile picture updated");
        DialogService.Close(true);
    }

    private async Task OnRemove()
    {
        _busy = true;
        try
        {
            await UserService.ClearOwnIconAsync();
            _changed = true;
            NotificationService.Notify(NotificationSeverity.Success, "Reverted to Gravatar");
            DialogService.Close(true);
        }
        catch (Exception ex) { NotifyError(ex); }
        finally { _busy = false; }
    }

    private void NotifyError(Exception ex) => NotificationService.Notify(NotificationSeverity.Error, "Update failed", ex.Message);
}
