@using System.Text.Json
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.JSInterop
@using Tharga.Team
@using Tharga.Toolkit
@inject IJSRuntime JS
@inject IUserService UserService
@inject IServiceProvider ServiceProvider
@inject DialogService DialogService

<CascadingAuthenticationState>
    <AuthorizeView>
        <Authorized>
            <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
                <RadzenCard>
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                        <UserAvatar User="_user" Size="64px" />
                        <RadzenStack Gap="0.25rem">
                            <RadzenText TextStyle="TextStyle.Subtitle1"><strong>@(_user?.Name ?? context.User.GetEmail())</strong></RadzenText>
                            @if (_canUpload)
                            {
                                <RadzenButton Text="Change picture" Icon="photo_camera" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="ChangePicture" />
                            }
                            else
                            {
                                <RadzenText TextStyle="TextStyle.Caption">To change your image, register your email at <RadzenLink Path="https://gravatar.com/" Target="gravatar">Gravatar</RadzenLink>.</RadzenText>
                            }
                        </RadzenStack>
                    </RadzenStack>
                </RadzenCard>
                <ExpandableCard Icon="work" Text="Claims">
                    <ChildContent>
                        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" class="rz-mb-2">
                            <RadzenButton Icon="content_copy" Text="Copy as JSON" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                          Click="@(() => CopyClaimsAsync(context.User))" />
                        </RadzenStack>
                        <ul style="word-break: break-all; overflow-wrap: break-word;">
                            @foreach (var claim in context.User.Claims)
                            {
                                <li><strong>@claim.Type:</strong> @claim.Value</li>
                            }
                        </ul>
                    </ChildContent>
                </ExpandableCard>
            </RadzenStack>
        </Authorized>
        <NotAuthorized>
            <RadzenText>Not authorized</RadzenText>
        </NotAuthorized>
    </AuthorizeView>
</CascadingAuthenticationState>

@code {
    private IUser _user;
    private bool _canUpload;

    protected override async Task OnInitializedAsync()
    {
        _user = await UserService.GetCurrentUserAsync();
        _canUpload = ServiceProvider.GetService<IIconStore>() != null;
    }

    private async Task ChangePicture()
    {
        var result = await DialogService.OpenAsync<UserIconDialog>("Profile picture",
            new Dictionary<string, object> { { nameof(UserIconDialog.HasIcon), !string.IsNullOrEmpty(_user?.Icon) } },
            new DialogOptions { Width = "480px" });

        if (result is true)
        {
            _user = await UserService.GetCurrentUserAsync();
            StateHasChanged();
        }
    }

    private async Task CopyClaimsAsync(System.Security.Claims.ClaimsPrincipal principal)
    {
        var data = new
        {
            IdentityName = principal.Identity?.Name,
            AuthenticationType = principal.Identity?.AuthenticationType,
            Claims = principal.Claims.Select(c => new { c.Type, c.Value }).ToArray()
        };
        var json = JsonSerializer.Serialize(data, new JsonSerializerOptions { WriteIndented = true });
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", json);
    }
}
