@using System.Text.Json
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.Extensions.Logging
@using Microsoft.Extensions.Options
@using Microsoft.JSInterop
@using Tharga.Team.Blazor.Features.User
@using Tharga.Toolkit
@typeparam TMember where TMember : class, Tharga.Team.ITeamMember
@inject ITeamService TeamService
@inject ITeamManagementService TeamManagementService
@inject ITeamStateService TeamStateService
@inject AuthenticationStateProvider AuthStateProvider
@inject IUserService UserService
@inject IJSRuntime Js
@inject DialogService DialogService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@inject IOptions<ThargaBlazorOptions> BlazorOptions
@inject IServiceProvider ServiceProvider
@inject ILogger<TeamComponent<TMember>> Logger

@* Current-user row highlight. Applied to the cells (not the <tr>) so Radzen's own cell backgrounds
   don't paint over it. The translucent blue composites correctly on both light and dark themes;
   colour-mix keeps the left accent visible against either. *@
<style>
    tr[data-tharga-current-member] > td {
        background-color: rgba(37, 99, 235, 0.16) !important;
    }

    tr[data-tharga-current-member] > td:first-child {
        box-shadow: inset 3px 0 0 0 var(--rz-primary, #2563eb);
    }
</style>

@if (_teams == null)
{
    <Loading />
}
else
{
    <RadzenStack Gap="1rem">
        <TeamInviteView TMember="TMember" />
        @if (_teams.Any())
        {
            @foreach (var team in _teams)
            {
                <ExpandableCard Text="@team.Name" Selected="@(_selectedTeam?.Key == team.Key)">
                    <TopMenu>
                        <TeamAvatar Team="team" Size="24px" />
                    </TopMenu>
                    <ChildContent>
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.Right" AlignItems="AlignItems.Center">
                        @if (_canSeeAllTeams)
                        {
                            <RadzenBadge BadgeStyle="@(Enum.Parse<BadgeStyle>(TeamVisibility.BadgeStyle(ConsentOf(team))))"
                                         Variant="Variant.Flat"
                                         Text="@TeamVisibility.Label(ConsentOf(team))"
                                         title="What this team has consented to grant you."
                                         class="rz-mr-2" />
                            @if (!IsMemberOf(team))
                            {
                                <RadzenBadge BadgeStyle="BadgeStyle.Light" Variant="Variant.Flat" Text="Not a member"
                                             title="You are viewing this team through cross-team access, not membership."
                                             class="rz-mr-2" />
                            }
                        }
                        @if (_showConsentToggle)
                        {
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem">
                                <RadzenLabel Text="@($"Consent access for {string.Join(", ", _consentRoles)}")" Style="font-size: 0.85em;" />
                                <RadzenDropDown TValue="AccessLevel?"
                                                Value="@(team.ConsentedRoles is { Length: > 0 } ? team.ConsentAccessLevel ?? AccessLevel.Viewer : (AccessLevel?)null)"
                                                Data="@_consentLevels"
                                                AllowClear="true"
                                                Disabled="@(!CanEditConsent(team))"
                                                Placeholder="No access"
                                                Change="@(async args => await SetConsent(team, (AccessLevel?)args))" />
                            </RadzenStack>
                        }
                        <RadzenButton icon="image" Text="Icon" Click="@(async () => { await SetTeamIcon(team); })" Visible="@(CanRenameTeam(team))"/>
                        <RadzenButton icon="edit" Text="Rename" Click="@(async () => { await RenameTeam(team); })" Visible="@(CanRenameTeam(team))"/>
                        <ActionButton icon="delete" Text="Delete" Click="@(async () => { await DeleteTeam(team); })" Visible="@(CanDeleteTeam(team))"/>
                        <RadzenButton icon="swap_horiz" Text="Transfer Ownership" Click="@(async () => { await TransferOwnership(team); })" Visible="@(HasAccessLevel(team, AccessLevel.Owner) && team.Members.Length > 1)"/>
                        <RadzenButton icon="remove" Text="Leave" Click="@(async () => { await RemoveUserFromTeam(team, _user.Key); })" Visible="@(CanLeaveTeam(team))"/>
                    </RadzenStack>
                    <RadzenRow>
                        <RadzenColumn>
                            @* <RadzenDataGrid Data="@team.Members" Visible="@(HasAccessLevel(team, AccessLevel.Administrator))" TItem="TMember"> *@
                            <RadzenDataGrid Data="@team.Members" TItem="TMember" RowRender="@OnMemberRowRender">
                                <Columns>
                                    @* <RadzenDataGridColumn Title="Key" Property="@nameof(ITeamMember.Key)" /> *@
                                    <RadzenDataGridColumn Title="EMail" SortOrder="SortOrder.Ascending">
                                        <Template>
                                            @{
                                                var user = _users.FirstOrDefault(x => x.Key == context.Key);
                                                <span style="margin-right: 6px;"><UserAvatar User="user" EMail="@(context.Invitation?.EMail ?? user?.EMail)" Name="@context.Name" Size="32px" /></span>
                                                @(context.Invitation?.EMail ?? user?.EMail)
                                            }
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn Title="Name" Property="@nameof(ITeamMember.Name)">
                                        <Template>
                                            @{
                                                var canEditThisRow = EnableMemberNameEdit && (_canManageMembers || context.Key == _user.Key);
                                                var isSelfEdit = context.Key == _user.Key;
                                            }
                                            @if (canEditThisRow && !string.IsNullOrEmpty(_editingMemberKey) && _editingMemberKey == context.Key)
                                            {
                                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem"
                                                             Style="min-width: 0; flex-wrap: nowrap;">
                                                    <RadzenTextBox Value="@_editingMemberName"
                                                                   ValueChanged="@(v => _editingMemberName = v)"
                                                                   Style="flex: 1 1 0; min-width: 0;" />
                                                    <RadzenButton Icon="check" ButtonStyle="ButtonStyle.Success" Variant="Variant.Flat" Size="ButtonSize.Small"
                                                                  Click="@(() => SaveMemberName(team, context))"
                                                                  Style="flex: 0 0 auto;" />
                                                    @if (!isSelfEdit && !string.IsNullOrEmpty(context.Name))
                                                    {
                                                        <RadzenButton Icon="restart_alt" ButtonStyle="ButtonStyle.Warning" Variant="Variant.Flat" Size="ButtonSize.Small"
                                                                      Click="@(() => ResetMemberName(team, context))"
                                                                      title="Clear override (use the global user name)"
                                                                      Style="flex: 0 0 auto;" />
                                                    }
                                                    <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Size="ButtonSize.Small"
                                                                  Click="@CancelMemberNameEdit"
                                                                  Style="flex: 0 0 auto;" />
                                                </RadzenStack>
                                            }
                                            else
                                            {
                                                var member = context;
                                                var user = _users.FirstOrDefault(x => x.Key == member.Key);
                                                var displayName = !string.IsNullOrEmpty(member.Name)
                                                    ? member.Name
                                                    : user?.Name ?? TeamServiceBase.ResolveDisplayName(user);
                                                var hasOverride = !string.IsNullOrEmpty(member.Name)
                                                                  && !string.IsNullOrEmpty(user?.Name)
                                                                  && member.Name != user.Name;
                                                var tooltip = hasOverride
                                                    ? $"Team override. Original name: {user.Name}"
                                                    : null;

                                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem">
                                                    <span title="@tooltip" style="@(hasOverride ? "font-style: italic;" : "")">@displayName</span>
                                                    @if (canEditThisRow)
                                                    {
                                                        <RadzenButton Icon="edit" Variant="Variant.Text" Size="ButtonSize.Small"
                                                                      Click="@(() => StartMemberNameEdit(member))"
                                                                      title="Edit display name" />
                                                    }
                                                </RadzenStack>
                                            }
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn Title="Access Level" Property="@nameof(ITeamMember.AccessLevel)">
                                        <Template>
                                            @if (_user.Key == context.Key || context.AccessLevel == AccessLevel.Owner) //Cannot change self or owner.
                                            {
                                                <RadzenText>@context.AccessLevel</RadzenText>
                                            }
                                            else if (_canManageMembers)
                                            {
                                                // Custom hidden until #76 adds member scope/role editing (see InviteUserDialog).
                                                var accessLevels = Enum.GetValues<AccessLevel>().Where(x => x != AccessLevel.Owner && x != AccessLevel.Custom);
                                                <RadzenDropDown TValue="AccessLevel" Value="@context.AccessLevel" ValueChanged="@(x => ChangeRole(team, context.Key, x))" Data="@accessLevels"/>
                                            }
                                            else
                                            {
                                                <RadzenText>@context.AccessLevel</RadzenText>
                                            }
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn Title="Roles" Width="200px" Visible="@(ShowRoles && _tenantRoleRegistry != null)">
                                        <Template>
                                            @if (_canManageMembers && _user.Key != context.Key && context.AccessLevel != AccessLevel.Owner)
                                            {
                                                <RoleEditor Roles="@GetVisibleRoles(team.Key)"
                                                            Selected="@(context.TenantRoles ?? Array.Empty<string>())"
                                                            SelectedChanged="@(r => ChangeTenantRoles(team, context.Key, r))" />
                                            }
                                            else
                                            {
                                                <RadzenText>@(string.Join(", ", context.TenantRoles ?? Array.Empty<string>()))</RadzenText>
                                            }
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn Title="Scope Overrides" Width="200px" Visible="@(ShowScopeOverrides && _scopeRegistry != null)">
                                        <Template>
                                            @if (_canManageMembers && _user.Key != context.Key && context.AccessLevel != AccessLevel.Owner)
                                            {
                                                <ScopeOverrideEditor AllScopes="_allScopeNames"
                                                                     Descriptions="_scopeDescriptions"
                                                                     InheritedScopes="@_scopeRegistry.GetEffectiveScopes(context.AccessLevel, context.TenantRoles, null)"
                                                                     Overrides="@(context.ScopeOverrides ?? Array.Empty<string>())"
                                                                     OverridesChanged="@(o => ChangeScopeOverrides(team, context.Key, o))" />
                                            }
                                            else
                                            {
                                                <RadzenText>@(string.Join(", ", context.ScopeOverrides ?? Array.Empty<string>()))</RadzenText>
                                            }
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn Title="Scopes" Width="80px" Visible="@(_scopeRegistry != null && ShowScopeTooltip)">
                                        <Template>
                                            <span title="@GetEffectiveScopesWithOriginText(team, context)">
                                                <RadzenIcon Icon="info" Style="cursor: help;" />
                                            </span>
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn Title="Status" Property="@nameof(ITeamMember.State)">
                                        <Template>
                                            @if (context.State == MembershipState.Invited && context.Invitation != null)
                                            {
                                                <span title="@($"Invited {context.Invitation.InviteTime:yyyy-MM-dd HH:mm} UTC")" style="cursor: help;">@context.State</span>
                                            }
                                            else
                                            {
                                                <span>@context.State</span>
                                            }
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn Title="Last Seen" Property="@nameof(ITeamMember.LastSeen)">
                                        <Template>
                                            <DateTimeView Date="@context.LastSeen"/>
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn>
                                        <Template>
                                            <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem">
                                                @if (_canManageMembers && context.Invitation != null)
                                                {
                                                    <span title="Copy invitation link">
                                                        <StandardButton Icon="link" Click="@(() => CopyInvitationLink(team, context.Key))"/>
                                                    </span>
                                                }
                                                @if (_canManageMembers && _user.Key != context.Key && context.AccessLevel != AccessLevel.Owner)
                                                {
                                                    <span title="Remove member">
                                                        <StandardButton Icon="remove" Click="@(() => RemoveUserFromTeam(team, context.Key))"/>
                                                    </span>
                                                }
                                            </RadzenStack>
                                        </Template>
                                    </RadzenDataGridColumn>
                                </Columns>
                            </RadzenDataGrid>
                        </RadzenColumn>
                    </RadzenRow>
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.Right">
                        <RadzenButton Icon="add" Text="Invite User" Click="@(() => AddUser(team))" Visible="@(_canManageMembers)"/>
                    </RadzenStack>
                    </ChildContent>
                </ExpandableCard>
            }
        }
        <RadzenText Visible="@(!_teams.Any() && _allowTeamCreation)">You are not member of a team. Create your own team and start inviting members.</RadzenText>
        <RadzenText Visible="@(!_teams.Any() && !_allowTeamCreation)">You are not member of a team.</RadzenText>
        @if (_allowTeamCreation)
        {
            <RadzenStack Orientation="Orientation.Horizontal">
                <RadzenButton Icon="add" Text="Create new Team" Click="@(() => CreateTeam())"/>
            </RadzenStack>
        }

    </RadzenStack>
}

@code {
    /// <summary>
    /// When true, callers with the <c>team:manage</c> scope can inline-edit a member's display name
    /// (Member.Name) via a pencil icon. When false (default), the Name column is read-only — preserves
    /// the existing behavior for consumers that haven't opted in.
    /// </summary>
    [Parameter] public bool EnableMemberNameEdit { get; set; }

    /// <summary>
    /// Optional callback invoked after a successful inline edit of <see cref="ITeamMember.Name"/>.
    /// Use to refresh derived caches, log additional context, etc.
    /// Platform handles the persistence itself; this is purely observational.
    /// </summary>
    [Parameter] public EventCallback<MemberNameChangedArgs> OnMemberNameChanged { get; set; }

    /// <summary>When true (and an <see cref="IScopeRegistry"/> is registered), shows the per-member effective-scope (i) tooltip. Default true.</summary>
    [Parameter] public bool ShowScopeTooltip { get; set; } = true;

    /// <summary>When true (and an <see cref="IScopeRegistry"/> is registered), shows the per-member scope-override editor column. Default false.</summary>
    [Parameter] public bool ShowScopeOverrides { get; set; }

    /// <summary>When true (and an <see cref="ITenantRoleRegistry"/> is registered), shows the per-member tenant-role editor column. Default false.</summary>
    [Parameter] public bool ShowRoles { get; set; }

    /// <summary>
    /// Optional callback invoked when the user activates the built-in "Create new Team" button.
    /// When set, it takes precedence over <see cref="ThargaBlazorOptions.CreateTeamPath"/> and the
    /// built-in create — letting a host launch its own onboarding flow (e.g. a dialog or wizard).
    /// When unset, the button navigates to <c>CreateTeamPath</c> (if configured), otherwise it
    /// performs the built-in <see cref="ITeamManagementService.CreateTeamAsync"/>.
    /// </summary>
    [Parameter] public EventCallback CreateTeamRequested { get; set; }

    private string _editingMemberKey;
    private string _editingMemberName;

    private ITeam<TMember>[] _teams;
    private IUser[] _users;
    private ITeam _selectedTeam;
    private IUser _user;
    private IReadOnlyList<TenantRoleDefinition> _roleDefinitions = Array.Empty<TenantRoleDefinition>();
    private ITenantRoleService _tenantRoleService;
    private bool _canManage;
    private bool _canManageMembers;
    private bool _canSeeAllTeams;
    private bool _allowTeamCreation;
    private string _createTeamPath;
    private bool _showConsentToggle;
    private string[] _consentRoles;
    private string[] _allScopeNames = Array.Empty<string>();
    private IReadOnlyDictionary<string, string> _scopeDescriptions = new Dictionary<string, string>();
    private IScopeRegistry _scopeRegistry;
    private ITenantRoleRegistry _tenantRoleRegistry;
    private ITenantRoleVisibilityProvider _roleVisibilityProvider;
    private readonly Dictionary<string, IReadOnlyList<TenantRoleDefinition>> _visibleRolesByTeam = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var claims = authState.User;
        _canManage = claims.HasClaim(TeamClaimTypes.Scope, TeamScopes.Manage);
        _canManageMembers = claims.HasClaim(TeamClaimTypes.Scope, TeamScopes.MemberManage);
        _canSeeAllTeams = TeamVisibility.CanSeeAllTeams(claims);

        _scopeRegistry = ServiceProvider.GetService<IScopeRegistry>();
        _tenantRoleRegistry = ServiceProvider.GetService<ITenantRoleRegistry>();
        _tenantRoleService = ServiceProvider.GetService<ITenantRoleService>();
        _roleVisibilityProvider = ServiceProvider.GetService<ITenantRoleVisibilityProvider>();

        _allowTeamCreation = BlazorOptions.Value.AllowTeamCreation;
        _createTeamPath = BlazorOptions.Value.CreateTeamPath;
        _showConsentToggle = BlazorOptions.Value.Consent.ShowToggle;
        _consentRoles = BlazorOptions.Value.Consent.Roles ?? [];
        if (_tenantRoleRegistry != null)
            _roleDefinitions = _tenantRoleRegistry.All;
        if (_scopeRegistry != null)
        {
            _allScopeNames = _scopeRegistry.All.Select(s => s.Name).ToArray();
            _scopeDescriptions = _scopeRegistry.All.ToDictionary(s => s.Name, s => s.Description);
        }

        _users = await UserService.GetAsync().ToArrayAsync();
        _user = await UserService.GetCurrentUserAsync();

        await ReloadTeams();

        await base.OnInitializedAsync();
    }

    private string GetEffectiveScopesWithOriginText(ITeam<TMember> team, TMember member)
    {
        if (_scopeRegistry == null) return "";

        var roleNames = member.TenantRoles ?? Array.Empty<string>();
        var accessLevelScopes = _scopeRegistry.GetScopesForAccessLevel(member.AccessLevel);
        var codeRoleScopes = _tenantRoleRegistry?.GetScopesForRoles(roleNames)
            ?? (IReadOnlyList<string>)Array.Empty<string>();
        var customRoleScopes = (_tenantRoleService != null ? team.CustomRoles ?? [] : [])
            .Where(r => roleNames.Contains(r.Name))
            .SelectMany(r => r.Scopes ?? []);
        var roleScopes = codeRoleScopes.Concat(customRoleScopes).ToHashSet(StringComparer.Ordinal);
        var overrides = member.ScopeOverrides ?? Array.Empty<string>();

        var allScopes = accessLevelScopes.Concat(roleScopes).Concat(overrides).Distinct();
        var lines = new List<string>();
        foreach (var scope in allScopes.OrderBy(s => s, StringComparer.Ordinal))
        {
            var origin = overrides.Contains(scope) ? "override"
                : roleScopes.Contains(scope) ? "role"
                : "access level";
            lines.Add($"{scope} ({origin})");
        }
        return string.Join("\n", lines);
    }

    private async Task ChangeTenantRoles(ITeam<TMember> team, string userKey, IEnumerable<string> roles)
    {
        var user = _users.FirstOrDefault(x => x.Key == userKey || x.Identity == userKey);
        var lookupKey = user?.Key ?? userKey;
        var member = team.Members.PickOneOrDefault(x => x.Key == lookupKey, Logger, team.Key, lookupKey);
        if (member == null)
        {
            NotifyMemberNotFound();
            return;
        }

        await TeamManagementService.SetMemberTenantRolesAsync(team.Key, member.Key, roles.ToArray());
        await ReloadTeams();
    }

    private async Task ChangeScopeOverrides(ITeam<TMember> team, string userKey, IEnumerable<string> scopes)
    {
        var user = _users.FirstOrDefault(x => x.Key == userKey || x.Identity == userKey);
        var lookupKey = user?.Key ?? userKey;
        var member = team.Members.PickOneOrDefault(x => x.Key == lookupKey, Logger, team.Key, lookupKey);
        if (member == null)
        {
            NotifyMemberNotFound();
            return;
        }

        await TeamManagementService.SetMemberScopeOverridesAsync(team.Key, member.Key, scopes.ToArray());
        await ReloadTeams();
    }

    private async Task CreateTeam()
    {
        switch (CreateTeamActionResolver.Resolve(CreateTeamRequested.HasDelegate, _createTeamPath))
        {
            case CreateTeamAction.Callback:
                await CreateTeamRequested.InvokeAsync();
                return;
            case CreateTeamAction.Navigate:
                NavigationManager.NavigateTo(_createTeamPath);
                return;
            default:
                await TeamManagementService.CreateTeamAsync();
                await ReloadTeams();
                return;
        }
    }

    private async Task RenameTeam(ITeam team)
    {
        var result = await DialogService.OpenAsync<TeamDialog<TMember>>(
            $"Rename {team.Name}",
            new Dictionary<string, object> { { "TeamKey", team.Key }, { "Name", team.Name } },
            new DialogOptions { Resizable = true, Draggable = true });

        if (result == true) await ReloadTeams();
    }

    private async Task SetTeamIcon(ITeam<TMember> team)
    {
        var result = await DialogService.OpenAsync<TeamIconDialog>(
            $"Icon — {team.Name}",
            new Dictionary<string, object>
            {
                { nameof(TeamIconDialog.TeamKey), team.Key },
                { nameof(TeamIconDialog.HasIcon), !string.IsNullOrEmpty(team.Icon) }
            },
            new DialogOptions { Width = "480px" });

        if (result is true) await ReloadTeams();
    }

    private async Task AddUser(ITeam<TMember> team)
    {
        var result = await DialogService.OpenAsync<InviteUserDialog>(
            "Invite User",
            new Dictionary<string, object> { { "TeamKey", team.Key }, { "TeamName", team.Name } },
            new DialogOptions { Resizable = true, Draggable = true });

        if (result is InviteUserDialog.InviteResult inviteResult && inviteResult.Success)
        {
            await ReloadTeams();

            var updatedTeam = await TeamService.GetTeamAsync<TMember>(team.Key);
            var invitedMember = updatedTeam?.Members
                .FirstOrDefault(m => m.Invitation != null && m.Name == inviteResult.Name);

            if (invitedMember?.Invitation != null)
            {
                var link = BuildInviteLink(updatedTeam.Key, invitedMember.Invitation.InviteKey);

                var emailSender = ServiceProvider.GetService<ITeamEmailSender>();
                if (emailSender != null && !string.IsNullOrWhiteSpace(inviteResult.Email))
                {
                    try
                    {
                        await emailSender.SendInviteAsync(inviteResult.Email, inviteResult.Name, link, team.Name);
                        NotificationService.Notify(NotificationSeverity.Success,
                            "Invitation sent", $"Email sent to {inviteResult.Email}");
                    }
                    catch (Exception ex)
                    {
                        NotificationService.Notify(NotificationSeverity.Warning,
                            "Email failed", $"Could not send email: {ex.Message}");
                    }
                }

                await Js.InvokeVoidAsync("clipboard.copyText", link);
                NotificationService.Notify(new NotificationMessage
                {
                    Summary = "The invitation link has been copied to the clipboard."
                });
            }
        }
    }

    private async Task RemoveUserFromTeam(ITeam<TMember> team, string userKey)
    {
        var user = _users.FirstOrDefault(x => x.Key == userKey || x.Identity == userKey);
        var lookupKey = user?.Key ?? userKey;
        var member = team.Members.PickOneOrDefault(x => x.Key == lookupKey, Logger, team.Key, lookupKey);
        if (member == null)
        {
            NotifyMemberNotFound();
            return;
        }

        var email = member.Invitation?.EMail ?? user?.EMail;
        var response = await DialogService.Confirm($"User '{email}' will be removed from the team '{team.Name}'.");
        if (response != true) return;

        await TeamManagementService.RemoveMemberAsync(team.Key, member.Key);
        await ReloadTeams();
    }

    private async Task ChangeRole(ITeam<TMember> team, string userKey, AccessLevel accessLevel)
    {
        var user = _users.FirstOrDefault(x => x.Key == userKey || x.Identity == userKey);
        var lookupKey = user?.Key ?? userKey;
        var member = team.Members.PickOneOrDefault(x => x.Key == lookupKey, Logger, team.Key, lookupKey);
        if (member == null)
        {
            NotifyMemberNotFound();
            return;
        }

        await TeamManagementService.SetMemberRoleAsync(team.Key, member.Key, accessLevel);
        await ReloadTeams();
    }

    private void NotifyMemberNotFound()
    {
        NotificationService.Notify(NotificationSeverity.Warning, "Member not found", "The member could not be located. Please reload the page.");
    }

    private void StartMemberNameEdit(TMember member)
    {
        _editingMemberKey = member.Key;
        _editingMemberName = member.Name ?? ResolveDefaultMemberName(member);
    }

    private void CancelMemberNameEdit()
    {
        _editingMemberKey = null;
        _editingMemberName = null;
    }

    private string ResolveDefaultMemberName(TMember member)
    {
        var user = _users.FirstOrDefault(x => x.Key == member.Key);
        return user?.Name ?? TeamServiceBase.ResolveDisplayName(user);
    }

    private async Task SaveMemberName(ITeam<TMember> team, TMember member)
    {
        var trimmed = string.IsNullOrWhiteSpace(_editingMemberName) ? null : _editingMemberName.Trim();
        var oldName = member.Name;
        var isSelfEdit = member.Key == _user.Key;

        if (isSelfEdit)
        {
            // Self-edit: this is "set my global name". Always overwrites User.Name; clear the
            // per-team Member.Name override in this team so the row falls through to User.Name.
            if (string.IsNullOrEmpty(trimmed))
            {
                CancelMemberNameEdit();
                return;
            }

            await UserService.SetUserNameAsync(_user.Key, trimmed);
            await TeamManagementService.SetMemberNameAsync(team.Key, _user.Key, null);
            CancelMemberNameEdit();
            await ReloadTeams();

            if (OnMemberNameChanged.HasDelegate)
            {
                await OnMemberNameChanged.InvokeAsync(new MemberNameChangedArgs(team.Key, member.Key, oldName, null));
            }
            return;
        }

        // Admin-edit on another row: per-team override.
        var defaultName = ResolveDefaultMemberName(member);

        // Auto-fallback: if the input matches the resolved default, persist null (no override).
        var newName = trimmed == defaultName ? null : trimmed;

        if (newName == oldName)
        {
            CancelMemberNameEdit();
            return;
        }

        await TeamManagementService.SetMemberNameAsync(team.Key, member.Key, newName);
        CancelMemberNameEdit();
        await ReloadTeams();

        if (OnMemberNameChanged.HasDelegate)
        {
            await OnMemberNameChanged.InvokeAsync(new MemberNameChangedArgs(team.Key, member.Key, oldName, newName));
        }
    }

    private async Task ResetMemberName(ITeam<TMember> team, TMember member)
    {
        var oldName = member.Name;
        if (oldName == null)
        {
            CancelMemberNameEdit();
            return;
        }

        await TeamManagementService.SetMemberNameAsync(team.Key, member.Key, null);
        CancelMemberNameEdit();
        await ReloadTeams();

        if (OnMemberNameChanged.HasDelegate)
        {
            await OnMemberNameChanged.InvokeAsync(new MemberNameChangedArgs(team.Key, member.Key, oldName, null));
        }
    }

    private async Task TransferOwnership(ITeam<TMember> team)
    {
        var eligibleMembers = team.Members
            .Where(x => x.Key != _user.Key && x.State == MembershipState.Member)
            .ToArray();

        if (eligibleMembers.Length == 0)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "No eligible members", "There are no other active members to transfer ownership to.");
            return;
        }

        var memberOptions = eligibleMembers.Select(m =>
        {
            var user = _users.FirstOrDefault(u => u.Key == m.Key);
            var display = user?.EMail ?? m.Name ?? m.Key;
            return new { m.Key, Display = display };
        }).ToArray();

        string selectedKey = memberOptions.First().Key;

        var result = await DialogService.OpenAsync("Transfer Ownership", ds =>
            @<RadzenStack Gap="1rem">
                <RadzenText>Select the new owner of team '@team.Name':</RadzenText>
                <RadzenDropDown TValue="string" @bind-Value="selectedKey"
                                Data="@memberOptions"
                                TextProperty="Display"
                                ValueProperty="Key" />
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.Right" Gap="0.5rem">
                    <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="@(_ => ds.Close(false))" />
                    <RadzenButton Text="Transfer" ButtonStyle="ButtonStyle.Warning" Click="@(_ => ds.Close(true))" />
                </RadzenStack>
            </RadzenStack>,
            new DialogOptions { Width = "400px" });

        if (result is not true) return;

        await TeamManagementService.TransferOwnershipAsync(team.Key, selectedKey);
        await ReloadTeams();
        NotificationService.Notify(NotificationSeverity.Success, "Ownership transferred");
    }

    private async Task DeleteTeam(ITeam<TMember> team)
    {
        var response = await DialogService.Confirm($"Team '{team.Name}' will be deleted.");
        if (response != true) return;

        await TeamManagementService.DeleteTeamAsync(team.Key);

        await ReloadTeams();
    }

    private readonly AccessLevel[] _consentLevels = [AccessLevel.Viewer, AccessLevel.User, AccessLevel.Administrator];

    private async Task SetConsent(ITeam<TMember> team, AccessLevel? level)
    {
        var roles = level.HasValue ? _consentRoles : Array.Empty<string>();
        await TeamService.SetTeamConsentAsync(team.Key, roles, level);
        await ReloadTeams();
    }

    private bool HasAccessLevel(ITeam<TMember> team, AccessLevel accessLevel)
    {
        var member = team.Members.PickOneOrDefault(x => x.Key == _user.Key, Logger, team.Key, _user.Key);
        if (member == null) return false;
        return member.AccessLevel <= accessLevel;
    }

    private void OnMemberRowRender(RowRenderEventArgs<TMember> args)
    {
        if (MemberHighlight.IsCurrentMember(args.Data?.Key, _user?.Key))
        {
            // Marker attribute only — the tint must be applied to the cells (see the <style> block at the
            // top of this component). Radzen's <td> cells carry their own background and would paint over
            // a background set on the <tr> here, so a row-level style is invisible.
            args.Attributes["data-tharga-current-member"] = "true";
        }
    }

    private bool IsMemberOf(ITeam<TMember> team)
    {
        return team.Members.Any(x => x.Key == _user.Key && x.State == MembershipState.Member);
    }

    private bool CanRenameTeam(ITeam<TMember> team)
    {
        return TeamActionGate.CanRename(_canManage, _selectedTeam?.Key, team.Key);
    }

    private bool CanDeleteTeam(ITeam<TMember> team)
    {
        return TeamActionGate.CanDelete(_canManage, _selectedTeam?.Key, team.Key, _allowTeamCreation, HasAccessLevel(team, AccessLevel.Owner));
    }

    private bool CanLeaveTeam(ITeam<TMember> team)
    {
        return TeamActionGate.CanLeave(IsMemberOf(team), HasAccessLevel(team, AccessLevel.Owner));
    }

    private bool CanEditConsent(ITeam<TMember> team)
    {
        return TeamActionGate.CanEditConsent(HasAccessLevel(team, AccessLevel.Administrator));
    }

    private async Task ReloadTeams()
    {
        _teams = null;
        _selectedTeam = await TeamStateService.GetSelectedTeamAsync();
        _teams = _canSeeAllTeams
            ? await TeamService.GetAllTeamsAsync<TMember>().ToArrayAsync()
            : await TeamService.GetTeamsAsync<TMember>().ToArrayAsync();
        await BuildVisibleRolesAsync();
        StateHasChanged();
    }

    private ConsentVisibility ConsentOf(ITeam<TMember> team)
    {
        return TeamVisibility.Resolve(team.ConsentedRoles, team.ConsentAccessLevel);
    }

    private async Task BuildVisibleRolesAsync()
    {
        _visibleRolesByTeam.Clear();
        if (_teams == null) return;

        foreach (var team in _teams)
        {
            var teamRoles = RolesForTeam(team);
            if (teamRoles.Count == 0)
            {
                _visibleRolesByTeam[team.Key] = teamRoles;
                continue;
            }

            if (_roleVisibilityProvider == null)
            {
                _visibleRolesByTeam[team.Key] = teamRoles;
                continue;
            }

            var visible = new List<TenantRoleDefinition>(teamRoles.Count);
            foreach (var role in teamRoles)
            {
                if (await _roleVisibilityProvider.IsRoleVisibleAsync(team.Key, role.Name))
                    visible.Add(role);
            }
            _visibleRolesByTeam[team.Key] = visible;
        }
    }

    // Code-registered roles plus (when dynamic roles are enabled) the team's own custom roles. Code roles
    // win on a name clash. Reads the team's custom roles from the already-loaded team document (no extra fetch).
    private IReadOnlyList<TenantRoleDefinition> RolesForTeam(ITeam<TMember> team)
    {
        if (_tenantRoleService == null || team.CustomRoles is not { Count: > 0 })
            return _roleDefinitions;

        var codeNames = _roleDefinitions.Select(r => r.Name).ToHashSet(StringComparer.Ordinal);
        return _roleDefinitions
            .Concat(team.CustomRoles.Where(r => !codeNames.Contains(r.Name)))
            .ToList();
    }

    private IReadOnlyList<TenantRoleDefinition> GetVisibleRoles(string teamKey)
        => _visibleRolesByTeam.TryGetValue(teamKey, out var roles) ? roles : _roleDefinitions;

    private async Task CopyInvitationLink(ITeam<TMember> team, string userKey)
    {
        var member = team.Members.PickOneOrDefault(x => x.Key == userKey, Logger, team.Key, userKey);
        if (member?.Invitation == null) return;

        var link = BuildInviteLink(team.Key, member.Invitation.InviteKey);

        await Js.InvokeVoidAsync("clipboard.copyText", link);
        NotificationService.Notify(new NotificationMessage
        {
            Summary = "The invitation link has been copied to the clipboard."
        });
    }

    private string BuildInviteLink(string teamKey, string inviteKey)
    {
        var inviteModel = new InviteModel { TeamKey = teamKey, Code = inviteKey };
        var inviteModelJson = JsonSerializer.Serialize(inviteModel);
        var inviteCode = inviteModelJson.ToBase64();
        return $"{NavigationManager.BaseUri}team?{Constants.TeamInviteCode}={inviteCode}";
    }

}
