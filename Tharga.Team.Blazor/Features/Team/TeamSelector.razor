@using Microsoft.Extensions.Options
@using Tharga.Team
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ITeamStateService TeamStateService
@inject ITeamService TeamService
@inject IThargaTextProvider TextProvider
@inject IOptions<ThargaBlazorOptions> BlazorOptions

<AuthorizeView>
    <Authorized>
        @if (_teams == null)
        {
            <RadzenProgressBarCircular Value="100" Mode="ProgressBarMode.Indeterminate" ShowValue="true" Size="ProgressBarCircularSize.ExtraSmall">
                <Template>@_loadingText</Template>
            </RadzenProgressBarCircular>
        }
        else if (_teams.Length == 0)
        {
            @if (CreateTeamRequested.HasDelegate)
            {
                <a href="" class="rz-link" @onclick="InvokeCreateTeamRequested" @onclick:preventDefault>@_createTeamText</a>
            }
            else
            {
                <RadzenLink Text="@_createTeamText" Path="@_createTeamPath" />
            }
        }
        else if (_teams.Length == 1 && SelectedTeam != null)
        {
            <TeamAvatar Team="SelectedTeam" Size="24px" />
            <span>@SelectedTeam.Name</span>
        }
        else if (_teams.Length > 1 && SelectedTeam != null)
        {
            <TeamAvatar Team="SelectedTeam" Size="24px" />
            <RadzenDropDown @bind-Value=@SelectedTeam Data="@(_teams.OrderBy(f => f.Name))" TextProperty="Name">
                <Template Context="team">
                    @if (_canSeeAllTeams)
                    {
                        <span style="@ConsentDotStyle((ITeam)team)" title="@TeamVisibility.Label(TeamVisibility.Resolve(((ITeam)team).ConsentedRoles, ((ITeam)team).ConsentAccessLevel))"></span>
                    }
                    @(((ITeam)team).Name)
                </Template>
            </RadzenDropDown>
        }
    </Authorized>
</AuthorizeView>

@code {
    /// <summary>
    /// Optional callback invoked when a teamless user activates the built-in "Create team" link.
    /// When set, it takes precedence over <see cref="ThargaBlazorOptions.CreateTeamPath"/> and the
    /// default <c>/team</c> navigation — letting a host launch its own onboarding flow (e.g. a dialog).
    /// When unset, the link navigates to <c>CreateTeamPath</c> (if configured) or <c>/team</c>.
    /// </summary>
    [Parameter] public EventCallback CreateTeamRequested { get; set; }

    private ITeam[] _teams;
    private bool _canSeeAllTeams;
    private ITeam _selectedTeam;
    private string _loadingText = TeamMenuText.Loading.Default;
    private string _createTeamText = TeamMenuText.CreateTeam.Default;
    private string _createTeamPath = "/team";

    private ITeam SelectedTeam
    {
        get => _selectedTeam;
        set
        {
            if (Equals(_selectedTeam, value)) return;
            _selectedTeam = value;
            TeamStateService.SetSelectedTeamAsync(_selectedTeam);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _loadingText = await TextProvider.GetAsync(TeamMenuText.Loading);
        _createTeamText = await TextProvider.GetAsync(TeamMenuText.CreateTeam);

        var configuredPath = BlazorOptions.Value.CreateTeamPath;
        if (!string.IsNullOrWhiteSpace(configuredPath)) _createTeamPath = configuredPath;

        TeamStateService.SelectedTeamChangedEvent += async (_, e) =>
        {
            _selectedTeam = e.SelectedTeam;
            await InvokeAsync(StateHasChanged);
        };

        TeamStateService.TeamsListChangedEvent += async (_, _) =>
        {
            await ReloadTeams();
        };

        TeamService.SelectTeamEvent += (_, e) =>
        {
            SelectedTeam = e.Team;
        };

        var current = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (current.User.Identity?.IsAuthenticated ?? false)
        {
            await ReloadTeams();
        }

        await base.OnInitializedAsync();
    }

    private async Task ReloadTeams()
    {
        var current = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _canSeeAllTeams = TeamVisibility.CanSeeAllTeams(current.User);
        _teams = _canSeeAllTeams
            ? await TeamService.GetAllTeamsAsync().ToArrayAsync()
            : await TeamService.GetTeamsAsync().ToArrayAsync();
        var selectedTeam = await TeamStateService.GetSelectedTeamAsync();
        SelectedTeam ??= selectedTeam;
        StateHasChanged();
    }

    private string ConsentDotStyle(ITeam team)
    {
        var visibility = TeamVisibility.Resolve(team.ConsentedRoles, team.ConsentAccessLevel);
        var token = TeamVisibility.BadgeStyle(visibility).ToLowerInvariant();
        return $"display:inline-block; width:.5rem; height:.5rem; border-radius:50%; background: var(--rz-{token}); margin-right:.4rem;";
    }

    private async Task InvokeCreateTeamRequested()
    {
        if (CreateTeamRequested.HasDelegate) await CreateTeamRequested.InvokeAsync();
    }
}
