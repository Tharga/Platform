@namespace Tharga.Team.Blazor.Framework

@*
    Tenant-role picker. Each option's tooltip shows the role's description (if any) plus the scopes the role
    grants — so the operator always sees what a role does, even without a description.
*@
<RadzenDropDown TValue="IEnumerable<string>"
                Multiple="true"
                AllowClear="true"
                Data="@_options"
                TextProperty="Name"
                ValueProperty="Name"
                Value="@_value"
                ValueChanged="@OnValueChanged"
                Placeholder="Select roles..."
                Style="@Style">
    <Template>
        <span title="@(((RoleOption)context).Tooltip)">@(((RoleOption)context).Name)</span>
    </Template>
</RadzenDropDown>

@code {
    /// <summary>
    /// The tenant roles to offer, already filtered to those visible for the current team. A role
    /// assigned to the member but absent here is treated as hidden: it stays assigned but is not
    /// shown or editable.
    /// </summary>
    [Parameter] public IReadOnlyList<TenantRoleDefinition> Roles { get; set; } = Array.Empty<TenantRoleDefinition>();

    /// <summary>Currently assigned role names.</summary>
    [Parameter] public IReadOnlyCollection<string> Selected { get; set; } = Array.Empty<string>();

    /// <summary>Invoked with the new set of assigned role names.</summary>
    [Parameter] public EventCallback<string[]> SelectedChanged { get; set; }

    [Parameter] public string Style { get; set; } = "min-width: 220px;";

    private List<RoleOption> _options = new();
    private IEnumerable<string> _value = Array.Empty<string>();
    private string[] _hiddenSelected = Array.Empty<string>();

    protected override void OnParametersSet()
    {
        var roles = Roles ?? Array.Empty<TenantRoleDefinition>();
        _options = roles.Select(r => new RoleOption(r.Name, BuildTooltip(r))).ToList();

        var (visible, hidden) = RoleSelectionResolver.Split(roles.Select(r => r.Name), Selected);
        _hiddenSelected = hidden.ToArray();
        _value = visible.ToList();
    }

    private static string BuildTooltip(TenantRoleDefinition role)
    {
        var scopes = role.Scopes is { Count: > 0 }
            ? "Grants: " + string.Join(", ", role.Scopes.OrderBy(s => s, StringComparer.Ordinal))
            : "Grants no scopes";
        return string.IsNullOrWhiteSpace(role.Description) ? scopes : $"{role.Description}\n{scopes}";
    }

    private async Task OnValueChanged(IEnumerable<string> value)
    {
        var selected = (value ?? Enumerable.Empty<string>()).ToList();
        _value = selected;
        await SelectedChanged.InvokeAsync(RoleSelectionResolver.Merge(selected, _hiddenSelected));
    }

    public sealed record RoleOption(string Name, string Tooltip);
}
